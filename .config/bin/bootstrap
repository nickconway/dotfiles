#!/bin/bash

set -xe

mkdir -p ~/.config/bin
mv $BASH_SOURCE ~/.config/bin/bootstrap

[[ -s ~/.config/bin/yadm ]] || (curl -fLo ~/.config/bin/yadm https://raw.githubusercontent.com/nickconway/dotfiles/master/.config/bin/yadm && chmod a+x ~/.config/bin/yadm)
export PATH=$PATH:~/.config/bin:~/.local/bin

yadm clone https://github.com/nickconway/dotfiles && yadm remote set-url origin "git@github.com:nickconway/dotfiles.git" || echo "Yadm already initialized"

if [[ $(yadm config local.class) == "" ]]; then
    read -p "Enter YADM class: " YADM_CLASS
    yadm config local.class $YADM_CLASS
fi

curl -fsSLo ~/.config/bin/devbox-install https://get.jetpack.io/devbox && chmod +x .config/bin/devbox-install

sed -i 's/readonly INSTALL_DIR="\/usr\/local\/bin"/readonly INSTALL_DIR="$HOME\/.local\/bin"/g' ~/.config/bin/devbox-install
sed -i "/confirm \"Install.*/d" ~/.config/bin/devbox-install
sed -i "s/$(command -v sudo || true) //g" ~/.config/bin/devbox-install

devbox-install
devbox global install
. <(devbox global shellenv --init-hook)

rustup default stable
rustup target add wasm32-wasi

git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && ~/.tmux/plugins/tpm/bin/install_plugins || ~/.tmux/plugins/tpm/bin/install_plugins

mkdir -p ~/.config/zellij/plugins
curl -L "https://github.com/imsnif/multitask/releases/latest/download/multitask.wasm" -o ~/.config/zellij/plugins/multitask.wasm
curl -L "https://github.com/rvcas/room/releases/latest/download/room.wasm" -o ~/.config/zellij/plugins/room.wasm

if sudo -v; then
    alias sysyadm="yadm --yadm-dir /etc/yadm --yadm-data /etc/yadm/data"
    sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) clone -w / https://github.com/nickconway/dotfiles -f --single-branch --branch sys
    sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) remote set-url origin git@github.com:nickconway/dotfiles.git
    sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) reset --hard
    sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) alt

    sudo groupadd docker || echo "Group docker already exists"
    sudo usermod -aG docker $USER
fi

yadm reset --hard
yadm decrypt
yadm alt

sudo chsh $USER -s $(which zsh)
