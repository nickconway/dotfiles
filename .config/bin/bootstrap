#!/bin/bash

set -xe

sudo apt update -y
sudo apt upgrade -y

mkdir -p ~/.config/bin
[[ -s ~/.config/bin/yadm ]] || (curl -fLo ~/.config/bin/yadm https://raw.githubusercontent.com/nickconway/dotfiles/master/.config/bin/yadm && chmod a+x ~/.config/bin/yadm)
export PATH=$PATH:~/.config/bin

yadm clone https://github.com/nickconway/dotfiles || echo "Yadm already initialized"
yadm remote set-url origin "git@github.com:nickconway/dotfiles.git"
yadm decrypt
yadm alt

curl -fsSLo ~/.config/bin/devbox-install https://get.jetpack.io/devbox && chmod +x .config/bin/devbox-install
devbox-install
devbox global install
. <(devbox global shellenv --init-hook)

rustup default stable

git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && ~/.tmux/plugins/tpm/bin/install_plugins || ~/.tmux/plugins/tpm/bin/install_plugins

mkdir -p ~/.config/zellij/plugins
curl -L "https://github.com/imsnif/multitask/releases/latest/download/multitask.wasm" -o ~/.config/zellij/plugins/multitask.wasm
curl -L "https://github.com/rvcas/room/releases/latest/download/room.wasm" -o ~/.config/zellij/plugins/room.wasm

sudo groupadd docker || echo "Group docker already exists"
sudo usermod -aG docker $USER

sudo chsh nick -s $(which zsh)
