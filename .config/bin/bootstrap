#!/bin/bash

set -xe
sudo apt update -y
sudo apt upgrade -y
mkdir -p ~/.config/bin
[[ -e ~/.config/bin/yadm ]] || (curl -fLo ~/.config/bin/yadm https://raw.githubusercontent.com/nickconway/dotfiles/master/.config/bin/yadm && chmod a+x ~/.config/bin/yadm)
export PATH=$PATH:~/.config/bin

yadm clone https://github.com/nickconway/dotfiles || echo "Yadm already initialized"
yadm remote set-url origin "git@github.com:nickconway/dotfiles.git"
export GPG_TTY=$(tty)
yadm decrypt
yadm alt

curl -fsSLo ~/.config/bin/devbox-install https://get.jetpack.io/devbox && chmod +x .config/bin/devbox-install
devbox-install
devbox global install
. <(devbox global shellenv --init-hook)

sudo chsh nick -s /home/nick/.local/share/devbox/global/default/.devbox/virtenv/.wrappers/bin/zsh
zsh
