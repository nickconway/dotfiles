#!/usr/bin/env bash

failed=()

build_project(){
    workspace=$1
    project=$2

    sudo echo "" > /tmp/eclipse-build-log
    if [[ $project == kojob ]]; then
        cd $KODIR/kojob
        sudo yum install -y libtool
        libtoolize
        aclocal
        autoconf
        automake --add-missing
        autoreconf
        mkdir -p Debug_Linux; cd Debug_Linux
        ../configure --prefix=/usr
        make
        sudo make install
        echo
        cd Debug
        echo $project $config
        make clean 2>&1 | tee -a /tmp/eclipse-build-log 
        make 2&>1 | tee -a /tmp/eclipse-build-log 
    else
        if [[ -e $HOME/git/$workspace/$project/Debug_Linux ]]; then
            config=Debug_Linux
        else
            config=Debug
        fi
        echo $project $config
        eclipse --launcher.suppressErrors -nosplash -data $HOME/git/$workspace -application org.eclipse.cdt.managedbuilder.core.headlessbuild -cleanBuild $project/$config 2>&1 | tee -a /tmp/eclipse-build-log 
    fi
    errors=$(grep -i -e "[1-9] errors" -i -e "make.*Error" /tmp/eclipse-build-log)
    [[ -n $errors ]] && failed+=("$project")
}

build_projects(){
    workspace=$1

    for d in $(find $HOME/git/$1 -name ".cproject" -not -path '*/.metadata/*'); do
        project=$(basename $(dirname $d))
        build_project $workspace $project
        echo
    done
}

if [[ $# -eq 0 ]]; then
    build_projects classX
    build_projects KO
elif [[ $# -eq 1 ]]; then
    build_projects $1
elif [[ $# -eq 2 ]]; then
    build_project $1 $2
else
    for p in "${@:2}"; do
        build_project $1 $p 
    done
fi

echo ---------------------------------------------------------------------
echo "Build(s) completed"
if [[ -n $failed ]]; then
    echo "Failed:"
    for f in ${failed[@]}; do
        echo $f
    done
fi
