#!/bin/env bash

function get-files() {
    yadm -C $HOME ls-files

    for line in $(cat $HOME/.config/yadm/encrypt); do 
        for pattern in $line; do
            if [[ -e $pattern ]]; then
                if [[ -d $pattern ]]; then
                    fd . $pattern -H --type f
                else
                    echo $pattern
                fi
            fi
        done
    done
}

get-files | sort | uniq
