#!/bin/env bash

status=off

tmux set status off
while [[ 1 -eq 1 ]]
do
    res=$(tmux display -p '#{client_prefix}')
    if [[ status == off ]] && [[ res -eq 1 ]]; then
        status=on
        tmux set status on
    elif [[ status == on ]]
        status=off
        tmux set status off
    fi
done
