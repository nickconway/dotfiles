#!/bin/bash

set -xe
sudo apt update -y
sudo apt upgrade -y
mkdir -p ~/.config/bin
curl -fLo ~/.config/bin/yadm https://raw.githubusercontent.com/nickconway/dotfiles/master/.config/bin/yadm && chmod a+x ~/.config/bin/yadm
export PATH=$PATH:~/.config/bin

yadm clone https://github.com/nickconway/dotfiles -f
yadm remote set-url origin "git@github.com:nickconway/dotfiles.git"
yadm reset --hard
yadm decrypt
yadm alt

curl -fsSL https://get.jetpack.io/devbox | bash
. <(devbox global shellenv --init-hook)

sudo chsh nick -s $(which zsh)
