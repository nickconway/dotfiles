#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    dir=$1
    command() (find "$dir" -mindepth 1 -maxdepth 1 -type d)
else
    command() (find ~/ $PROJECT_DIR -mindepth 1 -maxdepth 1 -type d; zoxide query -l; tmux list-sessions -F "#S")
fi
selected=$(command | sort | uniq | fzf-tmux -p)

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected")
session_name=$(basename "$selected" | tr . _)

tmux_running=$(pgrep tmux)

sveltekit=svelte-kit
angular="angular.json"

if [[ -e ~/.config/tmuxp/"$selected_name".yaml ]]; then
    tmuxp load ~/.config/tmuxp/"$selected_name".yaml -y > /dev/null
elif [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$session_name" -c "$selected"
elif [[ -e $selected/.$sveltekit ]]; then
    TMUXP_START_DIR=$selected TMUXP_SESSION_NAME=$session_name tmuxp load ~/.config/tmuxp/"$sveltekit".yaml -y > /dev/null
elif [[ -e $selected/$angular ]]; then
    TMUXP_START_DIR=$selected TMUXP_SESSION_NAME=$session_name tmuxp load ~/.config/tmuxp/angular.yaml -y > /dev/null
elif ! tmux has-session -t "$session_name" 2> /dev/null; then
    tmux new-session -ds "$session_name" -c "$selected"
    tmux switch-client -t "$session_name"
else
    tmux switch-client -t "$session_name"
fi
