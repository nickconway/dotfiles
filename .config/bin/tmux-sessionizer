#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    dir=$1
    command() (find "$dir" -mindepth 1 -maxdepth 1 -type d; tmux list-sessions -F "#S")
else
    command() (find ~/ -mindepth 1 -maxdepth 1 -type d; zoxide query -l; tmux list-sessions -F "#S")
fi
selected=$(command | sort | uniq | fzf-tmux -p)

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected")
session_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)
if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$session_name" -c "$selected"
fi

if ! tmux has-session -t "$session_name" 2> /dev/null; then
    if [[ -e ~/.config/tmuxp/"$selected_name".yaml ]]; then
        tmuxp load ~/.config/tmuxp/"$selected_name".yaml -y > /dev/null
    else
        tmux new-session -ds "$session_name" -c "$selected"
        tmux switch-client -t "$session_name"
    fi
fi
