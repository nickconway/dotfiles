#!/bin/bash

set -xe

cd
export PATH=$PATH:~/bin:~/.local/bin
if [[ $(uname -n) == "steamdeck" ]]; then
    export SD=distrobox\ enter\ ubuntu\ --
fi

yadm remote set-url origin "git@github.com:nickconway/dotfiles.git"
yadm checkout .

if [[ $(yadm config local.class) == "" ]]; then
    read -p "Enter YADM class: " YADM_CLASS
    while [[ "$YADM_CLASS" != "n" ]]; do
        yadm config --add local.class $YADM_CLASS
        read -p "Enter another YADM class (n to quit): " YADM_CLASS
    done
fi

yadm decrypt
yadm alt

sudo grep $USER /etc/sudoers || sudo bash -c "echo $USER ALL=\(ALL\) NOPASSWD:ALL >> /etc/sudoers"
sudo grep "session optional pam_exec.so /usr/bin/ntfy-ssh" /etc/pam.d/sshd || sudo bash -c "echo session optional pam_exec.so /usr/bin/ntfy-ssh >> /etc/pam.d/sshd"

[[ $(ls "$HOME"/.gnupg/exported) ]] && gpg --import "$HOME"/.gnupg/exported/*

[[ "$(yadm config --get-all local.class)" == *"work"* ]] && [[ "$(yadm config --get-all local.class)" == *"vm"* ]] && work-setup

alias sysyadm="yadm --yadm-dir /etc/yadm --yadm-data /etc/yadm/data"
sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) clone -w / https://github.com/nickconway/dotfiles -f --single-branch --branch sys \
    && sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) remote set-url origin git@github.com:nickconway/dotfiles.git \
    && sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) reset --hard \
    && sudo env "PATH=$PATH" $(alias sysyadm | cut -d\' -f2) alt

curl -fsSLo ~/.local/bin/devbox-install https://get.jetpack.io/devbox && chmod +x ~/.local/bin/devbox-install
sed -i 's/readonly INSTALL_DIR="\/usr\/local\/bin"/readonly INSTALL_DIR="$HOME\/.local\/bin"/g' ~/.local/bin/devbox-install
sed -i '/confirm \"Install.*/d' ~/.local/bin/devbox-install
sed -i 's/$(command -v sudo || true) //g' ~/.local/bin/devbox-install

$SD curl -L https://nixos.org/nix/install | sh -s
devbox-install
devbox global install
. <(devbox global shellenv --init-hook)
export PATH=$PATH:~/bin:~/.local/bin
. ~/.config/shell/common/encrypted.sh

sudo rm /bin/node || true && sudo ln -s $(which node) /bin/node
sudo rm /bin/npm || true && sudo ln -s $(which npm) /bin/npm
sudo rm /usr/bin/node || true && sudo ln -s $(which node) /usr/bin/node
sudo rm /usr/bin/npm || true && sudo ln -s $(which npm) /usr/bin/npm
npm set prefix ~/.npm-global
sudo npm set prefix -g ~/.npm-global

git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && ~/.tmux/plugins/tpm/bin/install_plugins

eval `keychain -q --nogui --eval $(find $HOME/.ssh/ -name "id*" -not -path "*.pub")`
if [[ "$(yadm config --get-all local.class)" == *"work"* ]]; then
    source ~/.config/shell/common/work.sh && clone-all-work
else
    clone-all
fi

if [[ $(uname -r) != *"WSL"* ]] || [[ "$(yadm config local.class)" == *"work"* ]]; then 
    if [[ $(uname -n) == "steamdeck" ]]; then
	    git clone https://github.com/tailscale-dev/deck-tailscale.git
	    cd deck-tailscale
	    sudo bash tailscale.sh
	    sudo tailscale up --ssh --accept-routes --operator=deck --authkey $TAILSCALE_KEY
	    rm -rf deck-tailscale
	else
	    curl -fsSL https://tailscale.com/install.sh | sh
	    sudo tailscale up --ssh --accept-routes --authkey $TAILSCALE_KEY
	fi
fi

if ! command -v docker; then
    curl -fsSL https://get.docker.com -o ~/.local/bin/get-docker
    sh ~/.local/bin/get-docker
    sudo groupadd docker && sudo usermod -aG docker $USER && newgrp docker
fi

mkdir -p ~/.config/zellij/plugins
curl -L "https://github.com/imsnif/multitask/releases/latest/download/multitask.wasm" -o ~/.config/zellij/plugins/multitask.wasm
curl -L "https://github.com/rvcas/room/releases/latest/download/room.wasm" -o ~/.config/zellij/plugins/room.wasm

sudo chsh $USER -s $(which zsh)

yadm checkout .
