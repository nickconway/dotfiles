#!/bin/bash

set -xe

cd

FAILED_COMMANDS=()

export PATH=~/bin:~/.local/bin:~/.local/homebrew/bin:/home/linuxbrew/.linuxbrew/bin:$PATH
if [ -S $XDG_RUNTIME_DIR/agent.sock ]; then
    export SSH_AUTH_SOCK=$XDG_RUNTIME_DIR/agent.sock
else
    eval $(ssh-agent -t 12h -s -a $XDG_RUNTIME_DIR/agent.sock)
fi

yadm remote set-url origin "git@github.com:nickconway/dotfiles.git"
yadm checkout .bash_profile
yadm checkout .bashrc
yadm checkout .zshrc

if command -v termux-reload-settings; then
    apt update -y && apt upgrade -y
    pkg install openssh termux-api gnupg fzf -y
    yadm decrypt
    yadm alt
    exit
fi

if [[ $(yadm config local.class) == "" ]]; then
    read -p "Enter YADM class: " YADM_CLASS
    while [[ "$YADM_CLASS" != "n" ]] && [[ "$YADM_CLASS" != "" ]]; do
        yadm config --add local.class $YADM_CLASS
        read -p "Enter another YADM class (n to quit): " YADM_CLASS
    done
fi

export GPG_TTY=$(tty)
yadm decrypt
yadm alt

. ~/.config/shell/common/encrypted.sh

if [[ -e ~/.ssh/authorized_keys ]]; then
    for f in $(ls ~/.ssh/*.pub); do 
        grep -qF "$(cat $f)" ~/.ssh/authorized_keys || echo "$(cat $f)" >> ~/.ssh/authorized_keys
    done
else
    [[ $(ls ~/.ssh/*.pub) ]] && cat ~/.ssh/*.pub >> ~/.ssh/authorized_keys
fi

if [[ $(uname -n) == "steamdeck" ]]; then
    sudo steamos-readonly disable
    echo "keyserver hkps://keyserver.ubuntu.com" >> /etc/pacman.d/gnupg/gpg.conf
    sudo pacman-key --init
    sudo pacman-key --populate
    sudo pacman-key --refresh-keys
    yay -S base-devel
fi

sudo grep "$USER ALL=" /etc/sudoers || sudo bash -c "echo $USER ALL=\(ALL\) NOPASSWD:ALL >> /etc/sudoers" || FAILED_COMMANDS+="Disabling sudo password failed"
sudo grep "session optional pam_exec.so /usr/bin/ntfy-ssh" /etc/pam.d/sshd || sudo bash -c "echo session optional pam_exec.so /usr/bin/ntfy-ssh >> /etc/pam.d/sshd" || FAILED_COMMANDS+="NTFY ssh setup failed"

[[ $(ls "$HOME"/.gnupg/exported) ]] && gpg --import "$HOME"/.gnupg/exported/*

[[ "$(yadm config --get-all local.class)" == *"work"* ]] && [[ "$(yadm config --get-all local.class)" == *"vm"* ]] && work-setup

sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data clone -w / https://github.com/nickconway/dotfiles -f --single-branch --branch sys \
    && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data remote set-url origin git@github.com:nickconway/dotfiles.git \
    && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data reset --hard \
    && ([[ -e /etc/yadm/encrypt ]] && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data decrypt || echo "Does not exist") \
    && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data alt \
    || FAILED_COMMANDS+="System YADM failed"

if ! command -v tailscale > /dev/null; then
    if [[ $(uname -n) == "steamdeck" ]]; then
        git clone https://github.com/tailscale-dev/deck-tailscale.git
        cd deck-tailscale
        sudo bash tailscale.sh
        sudo tailscale up --ssh --accept-routes --operator=deck --authkey $TAILSCALE_KEY || FAILED_COMMAND+="Tailscale setup failed"
        cd
        rm -rf deck-tailscale
    elif [[ "$(uname -r)" != *"WSL"* ]] || [[ "$(yadm config --get-all local.class)" == *"work"* ]]; then
        curl -fsSL https://tailscale.com/install.sh | sh
        sudo tailscale up --ssh --accept-routes --authkey $TAILSCALE_KEY || FAILED_COMMANDS+="Tailscale setup failed"
    fi
else
    sudo tailscale update
fi

if [[ $(uname -n) == "steamdeck" ]]; then
    sudo touch /etc/subuid /etc/subgid
    sudo usermod --add-subuid 100000-165535 --add-subgid 100000-165535 $USER
    curl -s https://raw.githubusercontent.com/89luca89/distrobox/main/install | sh -s -- --prefix ~/.local
    curl -Lo ~/.local/bin/podman https://github.com/89luca89/podman-launcher/releases/latest/download/podman-launcher-amd64
    chmod +x .local/bin/podman
    distrobox create -i ubuntu
fi

if command -v apt-get > /dev/null; then
    sudo apt-get install build-essential procps curl file git -y
elif command -v yum > /dev/null; then
    sudo yum groupinstall 'Development Tools' -y
    sudo yum install procps-ng curl file git -y
elif command -v pacman > /dev/null; then
    sudo pacman -Syu base-devel procps-ng curl file git
fi
NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || (mkdir -p ~/.local/homebrew && curl -L https://github.com/Homebrew/brew/tarball/master | tar xz --strip 1 -C ~/.local/homebrew)
eval "$(brew shellenv)"
brew update --force --quiet
chmod -R go-w "$(brew --prefix)/share/zsh"
install-all

$HOMEBREW_PREFIX/opt/fzf/install --all

npm set prefix ~/.npm-global
sudo npm set prefix -g ~/.npm-global || npm set prefix -g ~/.npm-global || FAILED_COMMANDS+="Setting global npm prefix failed"

nvim --headless '+Lazy! sync' +qa

git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && ~/.tmux/plugins/tpm/bin/install_plugins

mkdir -p ~/.config/zellij/plugins
curl -L "https://github.com/imsnif/multitask/releases/latest/download/multitask.wasm" -o ~/.config/zellij/plugins/multitask.wasm
curl -L "https://github.com/rvcas/room/releases/latest/download/room.wasm" -o ~/.config/zellij/plugins/room.wasm
curl -L "https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" -o ~/.config/zellij/plugins/zjstatus.wasm

if [[ ! "$(uname -r)" == *"WSL"* ]] && [[ ! -e ~/.local/bin/docker ]]; then
    curl -fsSL https://get.docker.com/rootless -o ~/.local/bin/get-docker-rootless
    chmod +x ~/.local/bin/get-docker-rootless
    export DOCKER_BIN=~/.local/bin
    export SKIP_IPTABLES=1 
    sh ~/.local/bin/get-docker-rootless || (sh ~/.local/bin/get-docker-rootless | awk '/cat <<EOF.*/{flag=1;next}/EOF/{flag=0}flag' | sudo bash) && sh ~/.local/bin/get-docker-rootless

    sudo loginctl enable-linger $(whoami) || FAILED_COMMANDS+="Enabling user systemctl failed"
    export DOCKER_HOST=unix:///$XDG_RUNTIME_DIR/docker.sock
    systemctl --user start docker
    systemctl --user enable docker
    if [[ "$(yadm config --get-all local.class)" == *"server"* ]]; then
        sudo setcap cap_net_bind_service=ep $(which rootlesskit)
        sudo bash -c "echo 'net.ipv4.ip_unprivileged_port_start=0' >> /etc/sysctl.conf"
        sudo sysctl --system
        systemctl --user restart docker
    fi

    DOCKER_CONFIG=${DOCKER_CONFIG:-$HOME/.docker}
    mkdir -p $DOCKER_CONFIG/cli-plugins
    curl -SL https://github.com/docker/compose/releases/latest/download/docker-compose-linux-x86_64 -o $DOCKER_CONFIG/cli-plugins/docker-compose
    chmod +x $DOCKER_CONFIG/cli-plugins/docker-compose
fi

if command -v fc-cache > /dev/null; then
    mkdir -p ~/.local/share/fonts/hack-nerd-font
    wget -O Hack.zip https://github.com/ryanoasis/nerd-fonts/releases/latest/download/Hack.zip
    unzip -o Hack.zip -d ~/.local/share/fonts/hack-nerd-font
    fc-cache -fv
    rm -rf Hack.zip
fi

if [[ "$(yadm config --get-all local.class)" == *"surface"* ]]; then
    if command -v apt > /dev/null; then
        wget -qO - https://raw.githubusercontent.com/linux-surface/linux-surface/master/pkg/keys/surface.asc | gpg --dearmor | sudo dd of=/etc/apt/trusted.gpg.d/linux-surface.gpg
        echo "deb [arch=amd64] https://pkg.surfacelinux.com/debian release main" | sudo tee /etc/apt/sources.list.d/linux-surface.list
        sudo apt update -y
        sudo apt install linux-image-surface linux-headers-surface libwacom-surface iptsd -y
        sudo apt install linux-surface-secureboot-mok -y
        sudo update-grub
    fi
fi

yadm checkout .bash_profile
yadm checkout .bashrc
yadm checkout .zshrc

if [[ "$(yadm config --get-all local.class)" == *"work"* ]]; then
    source ~/.config/shell/common/work.sh && clone-all-work
else
    clone-all
fi

sudo grep "$(which zsh)" /etc/shells || sudo bash -c "echo $(which zsh) >> /etc/shells" || FAILED_COMMANDS+="Adding to /etc/shells"
sudo chsh $USER -s $(which zsh) || FAILED_COMMANDS+="Changing default shell failed"

echo "All done!"

if ! [[ ${#FAILED_COMMANDS[@]} -eq 0 ]]; then
    echo "The following commands failed"
fi

for f in "${FAILED_COMMANDS[@]}"; do
    echo "$f"
done

curl -d "Bootstrapping complete on $(hostname)" https://ntfy.conway.dev/notifications -H "Authorization: Bearer ${NTFY_TOKEN}"
