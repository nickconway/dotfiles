#!/usr/bin/env bash

set -xe

cd

source ~/.cargo/env
cargo install tree-sitter-cli

sudo rm -rf .neovim
git clone https://github.com/neovim/neovim ~/.local/neovim
cd .local/neovim && make CMAKE_BUILD_TYPE=Release CMAKE_EXTRA_FLAGS="-DCMAKE_INSTALL_PREFIX=$HOME/.local/neovim"
sudo make install
cd -
