[user]
	name = Nick Conway
{% if yadm.distro_family == "rhel centos fedora" %}
    email = nconway@fornetix.com
{% else %}
    email = nick@conway.dev
{% endif }

[init]
	defaultBranch = main

[merge]
	tool = "nvim"

[mergetool]
	keepBackup = false
	prompt = false

[mergetool "nvim"]
	cmd = "nvim -d -c \"wincmd l\" -c \"norm ]c\" \"$LOCAL\" \"$MERGED\" \"$REMOTE\""
