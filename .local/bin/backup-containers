#!/bin/bash

set -xe

export PATH=$PATH:/home/$USER/.local/share/devbox/global/default/.devbox/virtenv/.wrappers/bin:$HOME/.local/bin
. $HOME/.config/shell/common/encrypted.sh

cd ~
ntfy publish notifications "Backing up docker containers" | echo "Failed to notify of backup start"
stop-containers
sudo rsync -ahuvz --progress ~/docker ~/Dropbox/Documents/Backups/
sudo rsync -ahuvz --progress ~/.local/share/docker/volumes ~/Dropbox/Documents/Backups/docker/
start-containers
until ntfy publish notifications "Backing up complete" > /dev/null; do
    true
done
