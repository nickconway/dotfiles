#!/bin/bash

set -xe

export PATH=$PATH:/home/nick/.local/share/devbox/global/default/.devbox/virtenv/.wrappers/bin

cd ~
ntfy publish notifications "Backing up docker containers"
stop-containers
sudo tar czvf docker.tar.gz docker
start-containers
until ntfy publish notifications "Backing up complete" > /dev/null; do
    true
done
