#!/bin/bash

set -e

export CAN_SUDO
CAN_SUDO=$(sudo true && echo "true" || echo "false")

export PATH=~/bin:~/.local/bin:~/.local/homebrew/bin:/home/linuxbrew/.linuxbrew/bin:$PATH

cd

yadm remote set-url origin "git@github.com:nickconway/dotfiles.git"

if command -v termux-reload-settings; then
    apt update -y && apt upgrade -y
    pkg install openssh starship termux-api gnupg fzf dnsutils zsh -y
    mkdir -p ~/.zsh
    cd ~/.zsh
    [[ -e ~/.zsh/zsh-autosuggestions ]] || git clone https://github.com/zsh-users/zsh-autosuggestions
    [[ -e ~/.zsh/zsh-completions ]] || git clone https://github.com/zsh-users/zsh-completions.git
    [[ -e ~/.zsh/zsh-syntax-highlighting ]] || git clone https://github.com/zsh-users/zsh-syntax-highlighting.git
    cd ~
    export GPG_TTY
    GPG_TTY=$(tty)
    yadm decrypt
    yadm alt
    chsh -s zsh
    exit
fi

if [[ $(uname -n) == "steamdeck" ]]; then
    {
        sudo systemctl enable --now sshd
        sudo steamos-readonly disable
        sudo rm -rf /etc/pacman.d/gnupg
        sudo pacman-key --init
        sudo bash -c "echo 'keyserver hkps://keyserver.ubuntu.com' >> /etc/pacman.d/gnupg/gpg.conf"
        sudo pacman-key --init
        sudo pacman-key --populate archlinux
        sudo pacman -Syu --noconfirm
        sudo pacman -Sy base-devel --noconfirm
    } || echo "Steamdeck read-only disabling failed"

    [[ -e ~/.local/source/deck-tailscale ]] || git clone https://github.com/tailscale-dev/deck-tailscale.git ~/.local/source/deck-tailscale
    cd ~/.local/source/deck-tailscale
    sudo bash tailscale.sh
    source /etc/profile.d/tailscale.sh

    sudo tailscale up --ssh --accept-routes --operator=$(whoami) --authkey $VPN_KEY --advertise-tags=tag:client,tag:server 
    sudo tailscale set --auto-update
fi

if [[ $(yadm config --get-all local.class) == "" ]]; then
    while [[ "$YADM_CLASS" != "q" ]] || [[ "$YADM_CLASS" == "" ]]; do
        if [[ "$YADM_CLASS" != "" ]]; then
            yadm config --add local.class "$YADM_CLASS"
        fi
        read -rp "Enter YADM class [homebrew, passwordless, surface, system, vm, work] (q to quit): " YADM_CLASS
    done
fi

export GPG_TTY
GPG_TTY=$(tty)

yadm decrypt
yadm alt

if [[ "$(yadm config --get-all local.class)" == *"surface"* ]]; then
    if command -v apt > /dev/null && [[ ! -e /etc/apt/sources.list.d/linux-surface.list ]]; then
        wget -qO - https://raw.githubusercontent.com/linux-surface/linux-surface/master/pkg/keys/surface.asc | gpg --dearmor | sudo dd of=/etc/apt/trusted.gpg.d/linux-surface.gpg
        echo "deb [arch=amd64] https://pkg.surfacelinux.com/debian release main" | sudo tee /etc/apt/sources.list.d/linux-surface.list
        sudo apt update -o DPkg::Lock::Timeout=300 -y
        sudo apt install -o DPkg::Lock::Timeout=300 linux-image-surface linux-headers-surface libwacom-surface iptsd -y
        sudo apt install -o DPkg::Lock::Timeout=300 linux-surface-secureboot-mok -y
        sudo update-grub
    fi

    sudo mkdir -p /etc/libinput && \
        sudo bash -c "echo '[Microsoft Surface Laptop Studio Touchpad]' > /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchVendor=0x045E' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchProduct=0x09AF' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchUdevType=touchpad' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'AttrPressureRange=2:1' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'AttrPalmPressureThreshold=500' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo '' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo '[Microsoft Surface Laptop Studio Built-In Peripherals]' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchName=*Microsoft Surface*' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchDMIModalias=dmi:*svnMicrosoftCorporation:*pnSurfaceLaptopStudio:*' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'ModelTabletModeNoSuspend=1' >> /etc/libinput/local-overrides.quirks"   
fi

if [[ "$(yadm config --get-all local.class)" == *"system"* ]]; then
    [[ -e /etc/yadm/data/repo.git ]] \
        || sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data clone -w / https://github.com/nickconway/dotfiles -f --single-branch --branch sys \
        && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data remote set-url origin git@github.com:nickconway/dotfiles.git \
        && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data reset --hard \
        && ([[ -e /etc/yadm/data/archive ]] && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data decrypt || echo "Does not exist") \
        && sudo GPG_TTY="$GPG_TTY" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" PATH="$PATH" $(which yadm) --yadm-dir /etc/yadm --yadm-data /etc/yadm/data alt
fi

[[ -e .config/shell/common/encrypted.sh ]] && . ~/.config/shell/common/encrypted.sh

if [ -S "$XDG_RUNTIME_DIR"/agent.sock ]; then
    export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR"/agent.sock
else
    eval $(ssh-agent -t 12h -s -a "$XDG_RUNTIME_DIR"/agent.sock)
fi

if [[ "$(find ~/.ssh/*.pub | wc -l)" != "$(ssh-add -l | wc -l)" ]]; then 
    ssh-add
fi

if [[ -e ~/.ssh/authorized_keys ]]; then
    for f in ~/.ssh/*.pub; do 
        grep -qF "$(cat $f)" ~/.ssh/authorized_keys || echo "$(cat $f)" >> ~/.ssh/authorized_keys
    done
else
    [[ $(ls ~/.ssh/*.pub) ]] && cat ~/.ssh/*.pub >> ~/.ssh/authorized_keys
fi

[[ $(ls "$HOME"/.config/gpg) ]] && gpg --import "$HOME"/.config/gpg/*

if [[ "$(yadm config --get-all local.class)" == *"work"* && "$(yadm config --get-all local.class)" == *"vm"* ]]; then
    . ~/.config/shell/common/work.sh && work-setup
    curl -d "Work setup complete" https://ntfy.conway.dev/notifications -H "Authorization: Bearer ${NTFY_TOKEN}"
fi

if command -v fc-cache > /dev/null; then
    mkdir -p ~/.local/share/fonts/hack-nerd-font
    wget -O Hack.zip https://github.com/ryanoasis/nerd-fonts/releases/latest/download/Hack.zip
    unzip -o Hack.zip -d ~/.local/share/fonts/hack-nerd-font
    fc-cache -fv
    rm -rf Hack.zip
fi

(curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin launch=n) \
    && ln -sf ~/.local/kitty.app/bin/kitty ~/.local/kitty.app/bin/kitten ~/.local/bin/ \
    && mkdir -p ~/.local/share/applications \
    && cp ~/.local/kitty.app/share/applications/kitty.desktop ~/.local/share/applications/ \
    && cp ~/.local/kitty.app/share/applications/kitty-open.desktop ~/.local/share/applications/ \
    && sed -i "s|Icon=kitty|Icon=/home/$USER/.local/kitty.app/share/icons/hicolor/256x256/apps/kitty.png|g" ~/.local/share/applications/kitty*.desktop \
    && sed -i "s|Exec=kitty|Exec=/home/$USER/.local/kitty.app/bin/kitty|g" ~/.local/share/applications/kitty*.desktop

if [[ "$CAN_SUDO" == "true" ]]; then
    if command -v apt > /dev/null; then
        sudo apt install python3-pip -y
    else
        python3 -m ensurepip --upgrade
    fi
fi

command -v pip > /dev/null && pip install --user ansible

mkdir -p ~/Git
[[ -e ~/Git/ansible ]] || (cd ~/Git && git clone git@github.com:nickconway/ansible)

if command -v ansible /dev/null && [[ -e ~/Git/ansible/main.yml ]]; then
    (
        cd ~/Git/ansible
        ansible-playbook main.yml --limit localhost --ask-vault-pass
    )
fi

clone-all

echo "All done!"

curl -d "Bootstrapping complete on $(uname -n)" https://ntfy.conway.dev/notifications -H "Authorization: Bearer ${NTFY_TOKEN}" &> /dev/null
