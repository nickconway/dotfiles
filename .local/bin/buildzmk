#!/usr/bin/env bash

cd $PROJECT_DIR/zmk-config/config/include/
sed -i.bkp '/btclear/e cat ~/.config/zmk/leader.dtsi' leader.dtsi
sed -i '/leader_sequences/e cat ~/.config/zmk/macros.dtsi' leader.dtsi

test -f $DROPBOX && mkdir -p $DROPBOX/Documents/ZMK/"$1"/
cd $PROJECT_DIR/zmk/app
if [ $(find . $PROJECT_DIR/zmk -name $1_left.conf | wc -l) -gt 0 ]; then
    if [ "$2" = "nv" ]; then
        docker exec -it zmk bash -c "west build -p -d build/$1/left -b nice_nano_v2 -- -DZMK_CONFIG=/workspace/zmk-config/config -DSHIELD=\"$1_left nice_view_adapter nice_view\""
        docker exec -it zmk bash -c "west build -p -d build/$1/right -b nice_nano_v2 -- -DZMK_CONFIG=/workspace/zmk-config/config -DSHIELD=\"$1_right nice_view_adapter nice_view\""
    else
        docker exec -it zmk bash -c "west build -p -d build/$1/left -b nice_nano_v2 -- -DZMK_CONFIG=/workspace/zmk-config/config -DSHIELD=\"$1_left\""
        docker exec -it zmk bash -c "west build -p -d build/$1/right -b nice_nano_v2 -- -DZMK_CONFIG=/workspace/zmk-config/config -DSHIELD=\"$1_right\""
    fi
    test -f $DROPBOX && test build/$1 && cp build/$1/left/zephyr/zmk.uf2 $DROPBOX/Documents/ZMK/$1/left.uf2
    test -f $DROPBOX && test build/$1 && cp build/$1/right/zephyr/zmk.uf2 $DROPBOX/Documents/ZMK/$1/right.uf2
else
    if [ "$2" = "nv" ]; then
        docker exec -it zmk bash -c "west build -p -d build/$1/ -b nice_nano_v2 -- -DZMK_CONFIG=/workspace/zmk-config/config -DSHIELD=\"$1 nice_view_adapter nice_view\""
    else
        docker exec -it zmk bash -c "west build -p -d build/$1/ -b nice_nano_v2 -- -DZMK_CONFIG=/workspace/zmk-config/config -DSHIELD=\"$1\""
    fi
    test -f $DROPBOX && cp build/$1/zephyr/zmk.uf2 $DROPBOX/Documents/ZMK/$1/
fi

cd $PROJECT_DIR/zmk-config/config/include/
mv leader.dtsi.bkp leader.dtsi
