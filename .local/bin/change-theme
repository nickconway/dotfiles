#!/usr/bin/env bash
set -euo pipefail

if [[ -e ~/.env ]]; then
    source ~/.env
fi

function _cp() {
    if [[ ! -e "$1" ]]; then return; fi
    local DIR
    DIR="$(dirname "${@: -1}")"
    mkdir -p "$DIR" &>/dev/null || sudo mkdir -p "$DIR"
    cp "${@}" &>/dev/null || sudo cp "${@}"
}

alpha=0.7
reload=
random=
light=
eight=

if [[ -e ~/.cache/wal/colors.json ]]; then
    alpha=$(jq -r .alpha ~/.cache/wal/colors.json)
fi

OPTS_STRING+=("-a, --alpha: alpha='\$ARG'")
OPTS_STRING+=("-l, --light: light=true")
OPTS_STRING+=("-m, --method: method='\$ARG'")
OPTS_STRING+=("-n, --noctalia: noctalia=true")
OPTS_STRING+=("-r, --random: random=true")
OPTS_STRING+=("-s, --show-image: show_image=true")
OPTS_STRING+=("-R, --reload: reload=true")
OPTS_STRING+=("-8, --eight: eight=true")
OPTS_STRING+=("-g, --generate-only: generate_only=true")
OPTS_STRING+=("-N, --no-notification: no_notification=true")

eval "$(get-options "${OPTS_STRING[@]}" -- "$@")"

if [[ -t 0 ]]; then
    CMD=(fzf)
else
    CMD=(vicinae dmenu -p "Choose a wallpaper")
fi

if [[ "$reload" == "true" ]]; then
    INPUT="$(cat ~/.cache/wal/wal)"
elif [[ "$random" == "true" ]]; then
    INPUT="$WALLPAPER_DIR"
elif [[ -n "${ARGS[0]:-}" ]]; then
    INPUT="${ARGS[0]}"
else
    INPUT="$(echo >/tmp/wallpaper && cd "$WALLPAPER_DIR" && fd . $WALLPAPER_DIR --type f | "${CMD[@]}")"
fi

WAL_CMD=(uvx --with colorthief --with colorz --with haishoku --from pywal16 wal -q -i "$INPUT" -a "$alpha")

if [[ -z "$eight" ]]; then
    WAL_CMD+=(--cols16 "${method:-darken}")
fi

if [[ $light == true ]]; then
    WAL_CMD+=(-l)
fi

if command -v gum &>/dev/null; then
    gum spin --title "Generating colors" -- "${WAL_CMD[@]}"
else
    "${WAL_CMD[@]}"
fi

if [[ -n ${generate_only:-} ]]; then
    exit
fi

IMG="$(cat ~/.cache/wal/wal)"

if [[ -n ${show_image:-} ]]; then
    kitten icat "$IMG"
fi

files=(
    "$IMG $HOME/.config/wallpaper"
    "$HOME/.cache/wal/colors.sh $HOME/.config/shell/common/colors.sh"
    "$HOME/.cache/wal/colors-hyprland.lua $HOME/.config/hypr/include/colors.lua"
    "$HOME/.cache/wal/hyprvim.conf $HOME/.config/hyprvim/theme.conf"
    "$HOME/.cache/wal/vicinae.toml $HOME/.local/share/vicinae/themes/pywal.toml"
    "$HOME/.cache/wal/gradience.json $HOME/.config/presets/user/pywal.json"
    "$HOME/.cache/wal/pywal.kvconfig $HOME/.config/Kvantum/pywal/pywal.kvconfig"
    "$HOME/.cache/wal/pywal.svg $HOME/.config/Kvantum/pywal/pywal.svg"
    "$HOME/.cache/wal/colors-k9s.yaml $HOME/.config/k9s/skins/wal.yaml"
    "$HOME/.cache/wal/colors-gtk.css $HOME/.config/gtk-3.0/gtk.css"
    "$HOME/.cache/wal/colors-gtk.css $HOME/.config/gtk-4.0/gtk.css"
    "$HOME/.cache/wal/colors-feishin.css $HOME/.config/feishin/custom.css"
    "$HOME/.cache/wal/vesktop.css $HOME/.config/vesktop/themes/pywal.theme.css"
    "$HOME/.cache/wal/vesktop.css $HOME/.var/app/dev.vencord.Vesktop/config/vesktop/themes/pywal.theme.css"
    "$HOME/.cache/wal/colors-noctalia.json $HOME/.config/noctalia/colorschemes/PyWal/PyWal.json"
    "$HOME/.cache/wal/colors-noctalia.json $HOME/.config/noctalia/colors.json"
    "$HOME/.cache/wal/caelestia-schema.json $HOME/.local/state/caelestia/scheme.json"
)

if [[ "$(uname)" != "Darwin" ]]; then
    files+=(
        "$IMG /usr/share/sddm/themes/sugar-candy/Backgrounds/bg.png"
        "$HOME/.cache/wal/sugar-candy.conf /usr/share/sddm/themes/sugar-candy/theme.conf"
        "$IMG /usr/share/sddm/themes/ltmnight/Backgrounds/bg.png"
        "$HOME/.cache/wal/hyprltm.conf /usr/share/sddm/themes/ltmnight/Themes/hyprltm.cof"
    )
fi

if [[ -e ~/Projects/thyx/scripts/install ]]; then
    files+=("$IMG $HOME/Projects/thyx/backgrounds/wal")
    files+=("$HOME/.cache/wal/thyx.conf $HOME/Projects/thyx/theme.conf")
fi

if [[ "$IMG" == *".png" ]]; then
    files+=("$HOME/.config/wallpaper $HOME/.config/wallpaper.png")
else
    magick ~/.config/wallpaper{,.png} &
fi

for line in "${files[@]}"; do
    _cp ${line[*]}
done

magick "$IMG" -strip -resize 1000 -gravity center -extent 1000 -quality 90 ~/.cache/wal/wal.thmb &
(
    magick "$IMG" -strip -thumbnail 500x500^ -gravity center -extent 500x500 ~/.cache/wal/wal.sqre &&
        magick ~/.cache/wal/wal.sqre \( -size 500x500 xc:white -fill "rgba(0,0,0,0.7)" -draw "polygon 400,500 500,500 500,0 450,0" -fill black -draw "polygon 500,500 500,0 450,500" \) -alpha Off -compose CopyOpacity -composite ~/.cache/wal/wal.png &&
        mv ~/.cache/wal/wal.png ~/.cache/wal/wal.quad
) &
magick "$IMG" -strip -scale 10% -blur 0x3 -resize 100% ~/.cache/wal/wal.blur &

if [[ $light == true ]]; then
    gsettings set org.gnome.desktop.interface color-scheme "prefer-light" || true
else
    gsettings set org.gnome.desktop.interface color-scheme "prefer-dark" || true
fi

vicinae theme set pywal &>/dev/null || true

kvantummanager --set pywal &>/dev/null || true

echo "\$WALLPAPER = $IMG" >~/.config/hypr/include/wallpaper.conf

if pgrep start-hyprland &>/dev/null; then
    hyprctl --instance 0 hyprpaper wallpaper ", $IMG, " &>/dev/null || true

    for m in $(hyprctl --instance 0 monitors -j | jq '.[].name' | xargs); do
        [[ ${noctalia:-false} == true ]] || qs -c noctalia ipc call wallpaper set "$IMG" $m &>/dev/null ||
            {
                FILE="$HOME/.cache/noctalia/wallpapers.json"
                jq ".wallpapers[\"$m\"]=\"i\"" "$FILE" >"$FILE.new" &&
                    mv "$FILE"{.new,}
            }
    done
fi

dms ipc call wallpaper set "$IMG" &>/dev/null ||
    {
        FILE="$HOME/.local/state/DankMaterialShell/session.json"
        if [[ -e "$FILE" ]]; then
            jq ".wallpaperPath=\"$IMG\"" "$FILE" >"$FILE.new" &&
                mv "$FILE"{.new,}
        fi
    }
dms greeter sync &>/dev/null || true

caelestia wallpaper -N -f "$IMG" &>/dev/null ||
    {
        if [[ -e "$HOME/.local/state/caelestia/wallpaper" ]]; then
            echo "$IMG" >~/.local/state/caelestia/wallpaper/path.txt
            ln -sf "$IMG" ~/.local/state/caelestia/wallpaper/current
        fi
    }

(~/Projects/thyx/scripts/install --yes &>/dev/null || true) &

(
    if command -v distrobox-host-exec &>/dev/null; then
        distrobox-host-exec plasma-apply-wallpaperimage "$IMG" || true
    else
        plasma-apply-wallpaperimage "$IMG" || true
    fi
) &>/dev/null

if pgrep swaync &>/dev/null; then
    swaync-client -rs &>/dev/null
fi

gcc ~/.config/darkreader/pywal.c -o ~/.config/darkreader/pywal &>/dev/null &

homeassistant-pywal &

if pgrep openrgb &>/dev/null; then
    openrgb-pywal &
fi

fastfetch

if [[ -z ${no_notification:-} ]]; then
    eval "$(notify-send -e -h string:synchronous:theme -i "$IMG" "Theme" "Theme changed" --action "$0=Pick" --action "$0 --random=Random" --action "$0 --reload=Reload")"
fi
