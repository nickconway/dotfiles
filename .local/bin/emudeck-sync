#!/usr/bin/env bash
set -euo pipefail

eval "$(
    get-options \
        "-n, --dry-run: RSYNC_CMD+=' -n'" \
        "-i, --init: INIT=true" \
        -- \
        "$@"
)"

EMUDECK_DIR="$(jq -r '.storagePath' .config/EmuDeck/settings.json)/Emulation"

RSYNC_CMD=(
    rsync
    -Lahvz
    --no-g
    --no-o
    --progress
    --info=progress2
)

if [[ -z ${INIT:-} ]]; then
    RSYNC_CMD+=(-u)
else
    pull-saves
    pull-bios
    link-games
    exit
fi

function pull-saves() {
    echo "Pulling Saves"
    "${RSYNC_CMD[@]}" "$REMOTE_EMUDECK_DIR"/Saves/ "$EMUDECK_DIR/saves"
}

function push-saves() {
    echo "Pushing Saves"
    "${RSYNC_CMD[@]}" "$EMUDECK_DIR/saves/" "$REMOTE_EMUDECK_DIR"/Saves
}

function sync-saves() {
    pull-saves
    echo
    push-saves
}

function pull-games() {
    echo "Pulling Games"
    "${RSYNC_CMD[@]}" "$REMOTE_EMUDECK_DIR"/Games/ "$EMUDECK_DIR/roms"
}

function push-games() {
    echo "Pushing Games"
    "${RSYNC_CMD[@]}" "$EMUDECK_DIR/roms/" "$REMOTE_EMUDECK_DIR"/Games
}

function link-games() {
    if [[ -e "$EMUDECK_DIR/roms" ]] && [[ ! -L "$EMUDECK_DIR/roms" ]]; then
        mv "$EMUDECK_DIR"/roms{,-bkp}
    fi

    if [[ ! -e "$EMUDECK_DIR/roms" ]]; then
        ln -sf "$REMOTE_EMUDECK_DIR"/Games "$EMUDECK_DIR/roms"
    fi
}

function sync-games() {
    pull-games
    echo
    push-games
}

function pull-bios() {
    echo "Pulling BIOS"
    "${RSYNC_CMD[@]}" "$REMOTE_EMUDECK_DIR"/BIOS/ "$EMUDECK_DIR/bios"
}

function push-bios() {
    echo "Pushing BIOS"
    "${RSYNC_CMD[@]}" "$EMUDECK_DIR/bios/" "$REMOTE_EMUDECK_DIR"/BIOS
}

function sync-bios() {
    pull-bios
    echo
    push-bios
}

if [[ -z "${ARGS:-}" ]]; then
    sync-saves
    echo
    sync-bios
    echo
    link-games
    sync-games
elif [[ ${#ARGS} -eq 1 ]]; then
    "${ARGS[0]}"-saves
    echo
    "${ARGS[0]}"-bios
    echo
    "${ARGS[0]}"-games
else
    echo ${ARGS[@]:1}
    for arg in ${ARGS[@]:1}; do
        echo $arg
        "${ARGS[0]}"-"$arg"
    done
fi
