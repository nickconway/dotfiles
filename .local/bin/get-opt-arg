#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

OPTIND=$1
shift

TOKEN=${!OPTIND}

if [[ -n $TOKEN && $TOKEN != -* ]]; then
    OPTIND=$((OPTIND + 1))
    OPTARG=$TOKEN
else
    OPTARG=""
fi

echo "OPTIND='$OPTIND'"
echo "OPTARG='$OPTARG'"
