#!/usr/bin/env bash
set -euo pipefail

for ARG in "$@"; do
    if [[ "$ARG" == -- ]]; then
        shift
        break
    fi
    OPTS_ARR+=("$ARG")
    shift
done

ARGS=()
FLAGS=()

for F in "${OPTS_ARR[@]}"; do
    OPTS="$(cut -d ':' -f 1 <<<"$F")"
    ACTION="$(cut -d ':' -f 2- <<<"$F")"
    IFS=',' read -ra FL <<<"$OPTS"
    for L in "${FL[@]}"; do
        FLAGS+=("$(sed 's/^\s\+//' <<<"$L"):$(sed 's/^\s\+//' <<<"$ACTION")")
    done
done

function opt-arg() {
    IND=$(($1 + 1))
    shift

    TOKEN=${!IND:-}

    if [[ -n $TOKEN && $TOKEN != -* ]]; then
        echo "$TOKEN"
    fi
}

i=1
while [[ $i -le $# ]]; do
    FOUND=
    OPT_ARG_FOUND=

    if [[ "${!i}" == "--" ]]; then
        i=$((i + 1))
        break
    fi

    for F in "${FLAGS[@]}"; do
        OPT=$(cut -d ':' -f 1 <<<"$F")
        ACTION=$(cut -d ':' -f 2 <<<"$F")

        if [[ "${!i}" == "$OPT" ]]; then
            OPT_ARG="$(if grep -q '$ARG' <<<"$ACTION"; then opt-arg $i "$@"; fi)"
            echo "${ACTION//\$ARG/$OPT_ARG}"
            FOUND=true

            if [[ -n "$OPT_ARG" ]]; then
                i=$((i + 1))
            fi

            break
        elif [[ "${!i}" != --* && "${!i}" == -* ]]; then
            OPTS="${!i:1}"

            for ((j = 0; j < ${#OPTS}; j++)); do
                if [[ "${OPTS:$j:1}" == "${OPT:1}" ]]; then
                    OPT_ARG="$(if grep -q '$ARG' <<<"$ACTION"; then opt-arg $i "$@"; fi)"
                    echo "${ACTION//\$ARG/$OPT_ARG}"
                    FOUND=true

                    if [[ -n "$OPT_ARG" ]]; then
                        OPT_ARG_FOUND=true
                    fi
                fi
            done
        fi
    done

    if [[ -z "$FOUND" ]]; then
        ARGS+=("${!i}")
    fi

    if [[ -n "$OPT_ARG_FOUND" ]]; then
        i=$((i + 1))
    fi

    i=$((i + 1))
done

ARGS+=("${@:$i}")

if [[ "${#ARGS[@]}" -gt 0 ]]; then
    echo -n 'ARGS+=('
    for a in "${ARGS[@]}"; do
        echo -n "'$a' "
    done
    echo ')'
fi
