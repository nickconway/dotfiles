#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

if [[ ! -e ~/.cache/wal/homeassistant.json ]]; then
    exit
fi

source $HOME/.config/shell/common/encrypted.sh

while read -r line; do
    curl -fsSL -X POST -H "Authorization: Bearer $HOMEASSISTANT_API_KEY" -H "Content-Type: application/json" \
        -d '{ "entity_id": "light.'"$(cut -d ' ' -f 1 <<<$line)"'", "rgb_color": '"$(cut -d ' ' -f 2 <<<$line)"' }' \
        https://home.conway.dev/api/services/light/turn_on -o /dev/null
done < <(cat ~/.cache/wal/homeassistant.json | jq -rc '.lights[] | .name + " " + (.color | tostring)')

entities="[$(
    while read -r line; do
        if [[ -n "$line" ]]; then
            echo "\"light.$line\""
        fi
    done < <(cat ~/.cache/wal/homeassistant.json | jq -rc '.lights[].name') | xargs -I '{}' echo -n "\"{}\", "
)]"
entities="${entities//, \]/\]}"

curl -fsSL -X POST -H "Authorization: Bearer $HOMEASSISTANT_API_KEY" -H "Content-Type: application/json" \
    -d '{ "scene_id": "pywal", "snapshot_entities": '"$entities"' }' \
    https://home.conway.dev/api/services/scene/create -o /dev/null
