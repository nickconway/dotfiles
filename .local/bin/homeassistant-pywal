#!/usr/bin/env bash
set -euo pipefail

FILE="$HOME/.cache/wal/homeassistant-$HOSTNAME.json"

if [[ ! -e "$FILE" ]]; then
    exit
fi

source $HOME/.config/shell/common/encrypted.sh

while read -r line; do
    curl -fsSL -X POST -H "Authorization: Bearer $HOMEASSISTANT_API_KEY" -H "Content-Type: application/json" \
        -d '{ "entity_id": "light.'"$(cut -d ' ' -f 1 <<<$line)"'", "rgb_color": '"$(cut -d ' ' -f 2 <<<$line)"' }' \
        https://home.conway.dev/api/services/light/turn_on -o /dev/null
done < <(jq -rc '.lights[] | .name + " " + (.color | tostring)' "$FILE")

entities="[$(
    while read -r line; do
        if [[ -n "$line" ]]; then
            echo "\"light.$line\""
        fi
    done < <(jq -rc '.lights[].name' "$FILE") | xargs -I '{}' echo -n "\"{}\", "
)]"
entities="${entities//, \]/\]}"

curl -sSL -X POST -H "Authorization: Bearer $HOMEASSISTANT_API_KEY" -H "Content-Type: application/json" \
    -d '{ "entity_id": "scene.pywal" }' \
    https://home.conway.dev/api/services/scene/delete -o /dev/null

sleep 3

curl -fsSL -X POST -H "Authorization: Bearer $HOMEASSISTANT_API_KEY" -H "Content-Type: application/json" \
    -d '{ "scene_id": "pywal", "snapshot_entities": '"$entities"' }' \
    https://home.conway.dev/api/services/scene/create -o /dev/null

curl -sSL -X POST -H "Authorization: Bearer $HOMEASSISTANT_API_KEY" -H "Content-Type: application/json" \
    -d '{ "entity_id": "scene.pywal" }' \
    https://home.conway.dev/api/services/scene/turn_on -o /dev/null
