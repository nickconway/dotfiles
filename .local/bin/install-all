#!/bin/bash

set -xe

if [[ $(uname -n) == "steamdeck" ]]; then
    sudo systemctl enable --now sshd
    sudo steamos-readonly disable
    sudo rm -rf /etc/pacman.d/gnupg
    sudo pacman-key --init
    sudo bash -c "echo 'keyserver hkps://keyserver.ubuntu.com' >> /etc/pacman.d/gnupg/gpg.conf"
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    sudo pacman -Syu
    sudo pacman -Sy base-devel
fi

CAN_SUDO=$(sudo true && echo "true" || echo "false")

PROCS=()

{
    if [[ ! ("$(yadm config --get-all local.class)" == *"work"* && "$(yadm config --get-all local.class)" == *"vm"*) ]]; then
        if ! command -v brew > /dev/null; then
            if command -v apt-get > /dev/null; then
                sudo apt-get install build-essential procps curl file git -y
            elif command -v yum > /dev/null; then
                sudo yum groupinstall 'Development Tools' -y && sudo yum install procps-ng curl file git -y
            elif command -v pacman > /dev/null; then
                sudo pacman -Syu base-devel procps-ng curl file git
            fi
            NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
            eval "$(brew shellenv)"
            brew update --force --quiet
            chmod -R go-w "$(brew --prefix)/share/zsh"
            brew install \
                neovim \
                sshfs \
                zsh \
                tree \
                the_silver_searcher \
                htop \
                tmux \
                tmuxp \
                cmake \
                rsync \
                gcc 
        else
            brew update
        fi
    else
        curl -SL https://github.com/neovim/neovim/releases/latest/download/nvim.appimage -o ~/.local/bin/nvim && chmod +x ~/.local/bin/nvim
    fi
} &> /tmp/yadm-brew &
PROCS+=($!)

([[ -e ~/.tmux/plugins/tpm ]] || git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && ~/.tmux/plugins/tpm/bin/install_plugins) &> /tmp/yadm-tpm &
PROCS+=($!)

(git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf && ~/.fzf/install --all || (cd ~/.fzf && git pull && ~/.fzf/install --all)) &> /tmp/yadm-fzf &
PROCS+=($!)

(curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh | bash) &> /tmp/yadm-nvm &
PROCS+=($!)

(curl -sS https://starship.rs/install.sh | sh -s -- --bin-dir $HOME/.local/bin -y) &> /tmp/yadm-starship &
PROCS+=($!)

(wget https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 -O ~/.local/bin/yq && chmod +x ~/.local/bin/yq) &> /tmp/yadm-yq &
PROCS+=($!)

{
    curl -SL https://github.com/zellij-org/zellij/releases/latest/download/zellij-x86_64-unknown-linux-musl.tar.gz -O && tar -xvf zellij*.tar.gz && chmod +x ./zellij && mv ./zellij ~/.local/bin/zellij && rm zellij*.tar.gz
    mkdir -p ~/.config/zellij/plugins
    curl -L "https://github.com/imsnif/multitask/releases/latest/download/multitask.wasm" -o ~/.config/zellij/plugins/multitask.wasm
    curl -L "https://github.com/rvcas/room/releases/latest/download/room.wasm" -o ~/.config/zellij/plugins/room.wasm
    curl -L "https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" -o ~/.config/zellij/plugins/zjstatus.wasm
} &> /tmp/yadm-zellij &
PROCS+=($!)

(curl -sS https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash) &> /tmp/yadm-zoxide &
PROCS+=($!)

{
    [[ -e ~/.cargo/env ]] && source ~/.cargo/env;
    command -v rustup > /dev/null && rustup update || (curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y; rustup default stable)
    cargo install --locked bat &
    cargo install fd-find &
    cargo install rbw &
    cargo install ripgrep &
    cargo install tealdeer &
    cargo install tree-sitter-cli &
} &> /tmp/yadm-cargo &
PROCS+=($!)

{
    [[ -e ~/.go ]] && chmod -R +rwx ~/.go && rm -rf ~/.go
    wget https://go.dev/dl/go1.21.5.linux-amd64.tar.gz
    tar -C ~ -xzf go1.21.5.linux-amd64.tar.gz
    mv ~/go ~/.go
    export GOPATH=~/.go
    ~/.go/bin/go install github.com/jesseduffield/lazygit@latest
    curl https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash
    rm ~/go*.linux-amd64.tar.gz

    git clone https://github.com/cli/cli.git ~/gh-cli
    cd gh-cli
    make install prefix=$HOME/.local
    rm -rf ~/gh-cli
} &> /tmp/yadm-gh-cli &
PROCS+=($!)

{
    mkdir -p ~/.zsh
    cd ~/.zsh
    [[ -e ~/.zsh/zsh-autosuggestions ]] || git clone https://github.com/zsh-users/zsh-autosuggestions
    [[ -e ~/.zsh/zsh-completions ]] || git clone https://github.com/zsh-users/zsh-completions.git
    [[ -e ~/.zsh/zsh-syntax-highlighting ]] || git clone https://github.com/zsh-users/zsh-syntax-highlighting.git
    cd ~
} &> /tmp/yadm-zsh-extras &
PROCS+=($!)

{
    if ! command -v tailscale > /dev/null; then
        if [[ "$(uname -r)" != *"WSL"* ]]; then
            if [[ $(uname -n) == "steamdeck" ]]; then
                git clone https://github.com/tailscale-dev/deck-tailscale.git
                cd deck-tailscale
                sudo bash tailscale.sh
                sudo tailscale up --ssh --accept-routes --operator=deck --authkey $TAILSCALE_KEY
                cd
                rm -rf deck-tailscale
            elif [[ "$CAN_SUDO" == "true" && "$(yadm config --get-all local.class)" != *"no-tailscale"* ]]; then
                curl -fsSL https://tailscale.com/install.sh | sh
                sudo tailscale up --ssh --accept-routes --authkey $TAILSCALE_KEY
            fi
        fi
    else
        [[ "$CAN_SUDO" == "true" ]] && sudo tailscale update
    fi
} &> /tmp/yadm-tailscale &
PROCS+=($!)

{
    if [[ "$(uname -r)" != *"WSL"* ]] && [[ ! -e ~/.local/bin/dockerd ]]; then
        curl -o .local/bin/slirp4netns --fail -L https://github.com/rootless-containers/slirp4netns/releases/latest/download/slirp4netns-$(uname -m)
        chmod +x .local/bin/slirp4netns

        curl -fsSL https://get.docker.com/rootless -o ~/.local/bin/get-docker-rootless
        chmod +x ~/.local/bin/get-docker-rootless
        export DOCKER_BIN=~/.local/bin
        export SKIP_IPTABLES=1 
        sh ~/.local/bin/get-docker-rootless || ([[ $CAN_SUDO == "true" ]] && sh ~/.local/bin/get-docker-rootless | awk '/cat <<EOF.*/{flag=1;next}/EOF/{flag=0}flag' | sudo bash) && sh ~/.local/bin/get-docker-rootless

        [[ $CAN_SUDO == "true" ]] && sudo setcap cap_net_bind_service=ep $(which rootlesskit)
        [[ $CAN_SUDO == "true" ]] && sudo bash -c "echo 'net.ipv4.ip_unprivileged_port_start=0' >> /etc/sysctl.conf"
        [[ $CAN_SUDO == "true" ]] && sudo sysctl --system
        mkdir -p ~/.config/systemd/user/docker.service.d
        echo "[Service]" > ~/.config/systemd/user/docker.service.d/override.conf
        echo 'Environment="DOCKERD_ROOTLESS_ROOTLESSKIT_PORT_DRIVER=slirp4netns"' >> ~/.config/systemd/user/docker.service.d/override.conf
        [[ $CAN_SUDO == "true" ]] && sudo loginctl enable-linger $(whoami)
        export DOCKER_HOST=unix:///$XDG_RUNTIME_DIR/docker.sock
        systemctl --user daemon-reload
        systemctl --user restart docker
        systemctl --user start docker
        systemctl --user enable docker

        export DOCKER_CONFIG=${DOCKER_CONFIG:-$HOME/.docker}
        mkdir -p $DOCKER_CONFIG/cli-plugins
        curl -SL https://github.com/docker/compose/releases/latest/download/docker-compose-linux-x86_64 -o $DOCKER_CONFIG/cli-plugins/docker-compose
        chmod +x $DOCKER_CONFIG/cli-plugins/docker-compose
        docker network inspect proxy || docker network create proxy
    fi
} &> /tmp/yadm-docker &
PROCS+=($!)

{
    (curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin launch=n) \
        && ln -sf ~/.local/kitty.app/bin/kitty ~/.local/kitty.app/bin/kitten ~/.local/bin/ \
        && mkdir -p ~/.local/share/applications \
        && cp ~/.local/kitty.app/share/applications/kitty.desktop ~/.local/share/applications/ \
        && cp ~/.local/kitty.app/share/applications/kitty-open.desktop ~/.local/share/applications/ \
        && sed -i "s|Icon=kitty|Icon=/home/$USER/.local/kitty.app/share/icons/hicolor/256x256/apps/kitty.png|g" ~/.local/share/applications/kitty*.desktop \
        && sed -i "s|Exec=kitty|Exec=/home/$USER/.local/kitty.app/bin/kitty|g" ~/.local/share/applications/kitty*.desktop
} &> /tmp/yadm-kitty &
PROCS+=($!)

{
    if [[ $(uname -n) == "steamdeck" ]]; then
        sudo touch /etc/subuid /etc/subgid
        sudo usermod --add-subuid 100000-165535 --add-subgid 100000-165535 $USER
        curl -s https://raw.githubusercontent.com/89luca89/distrobox/main/install | sh -s -- --prefix ~/.local
        curl -Lo ~/.local/bin/podman https://github.com/89luca89/podman-launcher/releases/latest/download/podman-launcher-amd64
        chmod +x .local/bin/podman
        distrobox create -i ubuntu
    fi
} &> /tmp/yadm-steamdeck-distrobox &
PROCS+=($!)

{
if [[ "$(yadm config --get-all local.class)" == *"surface"* ]]; then
    if command -v apt > /dev/null && [[ ! -e /etc/apt/sources.list.d/linux-surface.list ]]; then
        wget -qO - https://raw.githubusercontent.com/linux-surface/linux-surface/master/pkg/keys/surface.asc | gpg --dearmor | sudo dd of=/etc/apt/trusted.gpg.d/linux-surface.gpg
        echo "deb [arch=amd64] https://pkg.surfacelinux.com/debian release main" | sudo tee /etc/apt/sources.list.d/linux-surface.list
        sudo apt update -y
        sudo apt install linux-image-surface linux-headers-surface libwacom-surface iptsd -y
        sudo apt install linux-surface-secureboot-mok -y
        sudo update-grub
    fi

    sudo mkdir -p /etc/libinput && \
        sudo bash -c "echo '[Microsoft Surface Laptop Studio Touchpad]' > /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchVendor=0x045E' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchProduct=0x09AF' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchUdevType=touchpad' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'AttrPressureRange=2:1' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'AttrPalmPressureThreshold=500' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo '' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo '[Microsoft Surface Laptop Studio Built-In Peripherals]' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchName=*Microsoft Surface*' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'MatchDMIModalias=dmi:*svnMicrosoftCorporation:*pnSurfaceLaptopStudio:*' >> /etc/libinput/local-overrides.quirks" && \
        sudo bash -c "echo 'ModelTabletModeNoSuspend=1' >> /etc/libinput/local-overrides.quirks"   
fi
} &> /tmp/yadm-surface &
PROCS+=($!)

for pid in ${PROCS[@]}; do
    wait $pid
done
