#!/bin/bash

set -xe

brew install \
    neovim \
    zellij \
    tmux \
    node \
    nvm \
    bat \
    fd \
    zsh \
    zsh-autosuggestions \
    zsh-syntax-highlighting \
    rbw \
    tealdeer \
    zoxide \
    starship \
    lazygit \
    lazydocker \
    fzf \
    go \
    ripgrep \
    gh \
    yq \
    tree \
    bat \
    htop \
    curl \
    wget \
    tree-sitter \
    zsh-completions \
    tmuxp \
    cmake \
    ntfy \
    parallel \
    rsync \
    gcc \

command -v starship > /dev/null || curl -sS https://starship.rs/install.sh | sh -s -- --bin-dir $HOME/.local/bin

command -v fzf > /dev/null || git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf && ~/.fzf/install --all
$HOMEBREW_PREFIX/opt/fzf/install --all

command -v zoxide > /dev/null || curl -sS https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash

command -v tmux > /dev/null || (sudo yum install libevent ncurses libevent-devel gcc make bison pkg-config -y; git clone https://github.com/tmux/tmux.git && cd tmux && sh autogen.sh && ./configure --prefix $HOME/.local && make && make install && cd && rm -rf ~/tmux)
