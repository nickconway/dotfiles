#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

groupadd uinput || echo "group already exists"
usermod -aG input,uinput $USER

echo 'KERNEL=="uinput", MODE="0660", GROUP="uinput", OPTIONS+="static_node=uinput"' >/usr/lib/udev/rules.d/60-kmonad.rules
modprobe uinput
udevadm control --reload-rules && udevadm trigger
