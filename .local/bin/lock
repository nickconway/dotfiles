#!/usr/bin/env bash
set -euo pipefail

if pgrep -afx "qs .*caelestia.*" &>/dev/null; then
    qs -c caelestia ipc call lock lock
elif pgrep -afx "qs .*noctalia.*" &>/dev/null; then
    qs -c noctalia ipc call lockScreen lock
elif pgrep -afx "qs .*dms.*" &>/dev/null; then
    dms ipc call lock lock
elif ! pidof hyprlock; then
    hyprlock
fi
