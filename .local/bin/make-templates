#!/usr/bin/env bash
set -euo pipefail

if [[ -p /dev/stdin ]]; then
    readarray -t FILES
fi

FILES+=("${@}")

if [[ -z "${FILES:-}" || "${#FILES}" -eq 0 ]]; then
    readarray -t FILES < <(fd --hidden '%%')
fi

for f in "${FILES[@]}"; do
    if [[ ! -f "$f" ]] || [[ ! "$f" == *%%template* ]]; then
        continue
    fi

    new_file="${f/\%\%template*/}"

    echo "$f => $new_file"
    envsubst <"$f" >"$new_file"
done
