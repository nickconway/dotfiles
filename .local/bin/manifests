#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

function _apply() {
    cd "$1" || return 1

    if [[ -e setup ]]; then
        ./setup
    fi

    for f in *.yml; do
        kubectl apply -f <(envsubst <"$f")
    done
}

cd "${K8S_MANIFEST_DIR:-~/Kubernetes}"
CMD="$1"
shift

if [[ -p /dev/stdin ]]; then
    readarray -t TARGETS
elif [[ -n "$*" ]]; then
    TARGETS=("${@}")
else
    TARGETS=(*)
fi

if type "$CMD" &>/dev/null; then
    "$CMD" $*
    exit
else
    run -t "$(basename "$0") $CMD \$D" "$(basename "$0") _$CMD \$D" "${TARGETS[@]}"
fi
