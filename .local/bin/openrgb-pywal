#!/usr/bin/env python

from openrgb.utils import ModeData
import sys
from openrgb.utils import RGBColor
import os
from pathlib import Path
from openrgb.orgb import OpenRGBClient
import json
import random
import colorsys


def rgb_to_hex(color):
    """Convert an rgb color to hex."""
    return "#%02x%02x%02x" % (*color,)


def hex_to_rgb(color):
    """Convert a hex color to rgb."""
    return tuple(bytes.fromhex(color.strip("#")))


def saturate(color, amount):
    """Change saturation of a hex color to passed value.

    new_saturation = amount"""
    r, g, b = hex_to_rgb(color)
    r, g, b = [x / 255.0 for x in (r, g, b)]
    h, l, s = colorsys.rgb_to_hls(r, g, b)
    s = amount
    r, g, b = colorsys.hls_to_rgb(h, l, s)
    r, g, b = [x * 255.0 for x in (r, g, b)]

    return rgb_to_hex((int(r), int(g), int(b)))


try:
    client = OpenRGBClient()
except ConnectionRefusedError:
    print("Could not connect to OpenRGB")
    sys.exit()

colors = []

with open(Path(os.getenv("HOME")) / ".cache/wal/colors.json") as f:
    data = json.load(f)

for dev in client.devices:
    for zone in dev.zones:
        color = data.get("colors").get(f"color{random.randint(9, 14)}")
        color = saturate(color, 1)
        color = RGBColor.fromHEX(color)
        zone.set_color(color)

    mode = dev.modes[dev.active_mode]
    mode.brightness = mode.brightness_max

    dev.set_mode(mode)
    dev.save_mode()

client.save_profile("pywal")
