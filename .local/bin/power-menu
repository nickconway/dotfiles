#!/usr/bin/env bash
set -euo pipefail

if pgrep -afx "qs .*caelestia.*" &>/dev/null; then
    qs -c caelestia ipc call drawers toggle session
elif pgrep -afx "qs .*noctalia.*" &>/dev/null; then
    qs -c noctalia ipc call sessionMenu toggle
elif pgrep -afx "qs .*dms.*" &>/dev/null; then
    dms ipc call powermenu toggle
else
    ~/.config/rofi/scripts/power-menu
fi
