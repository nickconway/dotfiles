#!/usr/bin/env bash
set -euo pipefail

function choose() {
    mkdir -p ~/.config/quickshell
    SELECTED="$(find /etc/xdg/quickshell /usr/local /usr/share ~/.config/quickshell -name shell.qml -print0 | xargs -0 dirname | while read -r f; do basename "$f"; done | fzf --border-label " Choose QuickShell Config ")"
    [[ -n "$SELECTED" ]] && echo "$SELECTED" >~/.config/quickshell/config
}

function spawn() {
    killall qs || true
    CONFIG="$(cat ~/.config/quickshell/config)"

    if [[ "$CONFIG" == dms ]]; then
        CMD=(dms run)
    else
        CMD=(qs -c "$CONFIG")
    fi

    "${CMD[@]}" "$@"
}

"$@"
