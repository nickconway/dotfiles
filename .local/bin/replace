#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

if ! command -v rg &>/dev/null; then
    echo "rg not found"
    return
fi

if [ $# -lt 2 ]; then
    echo "Recursive, interactive text replacement"
    echo "Usage: replace text replacement"
    return
fi

F=c

eval "$(get-options "-f, --force: F=" -- "$@")"

FIND="${ARGS[0]}"
REPLACE="${ARGS[1]}"
SEARCH=("${ARGS[@]:2}")

read -ra FILES < <(rg --smart-case -l "$FIND" "${SEARCH[@]}" | xargs)

if [[ -n "${FILES:-}" ]] && [[ ${#FILES} -gt 0 ]]; then
    CMD=(
        nvim
        -c
        "':set nohlsearch | :argdo %s/$FIND/$REPLACE/g${F:-} | update'"
        -c
        qa
    )

    if [[ -n "$TMUX" ]]; then
        tmux display-popup -w 80% -h 80% -d $PWD -E "${CMD[*]} ${FILES[*]}"
    else
        "${CMD[@]}" "${FILES[@]}"
    fi

else
    echo Pattern not found
fi
