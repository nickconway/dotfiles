#!/usr/bin/env bash
set -euo pipefail

eval "$(get-options "-t, --title: OG_TITLE='\$ARG'" -- "$@")"

RED='\033[0;31m'
GREEN='\033[0;32m'
RESET='\033[0m'

if [[ -n "${DEBUG_MODE:-}" ]]; then
    export GUM_SPIN_SHOW_OUTPUT=true
    export GUM_SPIN_SHOW_STDOUT=true
fi

shopt -s dotglob

CMD_INIT="${ARGS[0]}"

if [[ -p /dev/stdin ]]; then
    readarray -t TARGETS
fi

TARGETS+=("${ARGS[@]:1}")

if [[ -z "${TARGETS:-}" ]]; then
    TARGETS+=(*)
fi

TMP=$(mktemp)

for D in "${TARGETS[@]}"; do
    export D
    INNER_CMD=("$(envsubst <<<"$CMD_INIT")")
    TITLE="$(envsubst <<<"${OG_TITLE:-}")"

    CMD=("$SHELL" -lc "export DEBUG_MODE=${DEBUG_MODE:-} && { ${INNER_CMD[@]}; } &> $TMP")

    if command -v gum &>/dev/null; then
        CMD=(gum spin --title "${TITLE:-${INNER_CMD[@]}}" -- "${CMD[@]}")
    fi

    if ("${CMD[@]}"); then
        echo -e "${GREEN}$RESET ${TITLE:-${INNER_CMD[@]}}"
    else
        echo -e "${RED}$RESET ${TITLE:-${INNER_CMD[@]}}"

        if [[ -n "$(cat "$TMP")" ]]; then
            echo -e $RED-----------------------------------------------------------$RESET
            echo
            cat "$TMP"
            echo
            echo -e $RED-----------------------------------------------------------$RESET
        fi
    fi
done

rm "$TMP"
