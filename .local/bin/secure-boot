#!/usr/bin/env bash
set -euo pipefail

sbctl create-keys
read -rp "Are you dual booting Windows? [y/N] " DB
if [[ $DB == "y" || $DB == "Y" ]]; then
    echo "Also enrolling microsoft keys..."
    grub-install --target=x86_64-efi --efi-directory /boot --bootloader-id=GRUB --modules="tpm" --disable-shim-lock
    sbctl enroll-keys --microsoft
else
    sbctl enroll-keys
fi
sbctl verify 2>&1 | tail -n +2 | awk '{print $2}' | while read -r LINE; do sbctl sign -s $LINE; done
sbctl sign-all
