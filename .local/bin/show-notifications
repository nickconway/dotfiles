#!/usr/bin/env bash
set -euo pipefail

if pgrep -afx "qs .*caelestia.*" &>/dev/null; then
    qs -c caelestia ipc call drawers toggle sidebar
elif pgrep -afx "qs .*noctalia.*" &>/dev/null; then
    qs -c noctalia ipc call notifications toggleHistory
elif pgrep -afx "qs .*dms.*" &>/dev/null; then
    dms ipc call notifications toggle
else
    swaync-client -t
fi
