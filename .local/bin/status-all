#! /bin/bash
for d in $(find $(pwd) -name .git -type d -prune -not -path '*flake*'); do
    cd $d
    cd ..
    if [[ $(git status --porcelain) != "" ]] && [[ $(git status --porcelain) != " M Makefile.Debug" ]] && [[ $(git status --porcelain) != " M Makefile.Debug_Linux" ]]; then
        pwd
        git status
        echo 
        echo -----------------------------
        echo 
    fi
done
