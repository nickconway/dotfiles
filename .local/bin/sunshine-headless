#!/usr/bin/env bash
set -euo pipefail

if [[ "$1" == "disable" ]]; then
    hyprctl reload
elif [[ "$1" == "enable" ]]; then
    for m in $(hyprctl monitors -j | jq -r '.[] | .name' | grep -v sunshine); do
        hyprctl eval "hl.monitor({ output = '$m', disabled = true })"
    done

    hyprctl eval 'hl.monitor({ output = "Sunshine", mode = "3840x2160@120" })'
fi
