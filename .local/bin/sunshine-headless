#!/usr/bin/env bash
set -euo pipefail

if [[ "$1" == "disable" ]]; then
    for m in $(hyprctl monitors all -j | jq -r '.[].name' | grep -iv sunshine); do
        hyprctl eval "hl.monitor({ output = '$m', disabled = false })"
    done

    hyprctl eval "hl.monitor({ output = 'Sunshine', disabled = true })"
elif [[ "$1" == "enable" ]]; then
    for m in $(hyprctl monitors all -j | jq -r '.[].name' | grep -iv sunshine); do
        hyprctl eval "hl.monitor({ output = '$m', disabled = true })"
    done

    WIDTH=${SUNSHINE_CLIENT_WIDTH:-3840}
    HEIGHT=${SUNSHINE_CLIENT_HEIGHT:-2160}
    RR=${SUNSHINE_CLIENT_FPS:-120}

    hyprctl eval "hl.monitor({ output = 'Sunshine', mode = '${WIDTH}x${HEIGHT}@${RR}', disabled = false })"
fi
