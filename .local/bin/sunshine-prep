#!/usr/bin/env bash
set -euo pipefail

WIDTH=${SUNSHINE_CLIENT_WIDTH:-3840}
HEIGHT=${SUNSHINE_CLIENT_HEIGHT:-2160}
FPS=${SUNSHINE_CLIENT_FPS:-120}

if [[ $1 == "do" ]]; then
    loginctl unlock-session
    pkill -STOP -x hypridle &>/dev/null

    for m in $(hyprctl monitors -j | jq -r '.[] | .name' | grep -v Sunshine); do
        hyprctl eval "hl.monitor({ output = \"$m\", disabled = true })"
    done

    hyprctl eval "hl.monitor({ output = 'Sunshine', mode = '${WIDTH}x${HEIGHT}@${FPS}' })"
elif [[ $1 == "undo" ]]; then
    pkill -CONT -x hypridle &>/dev/null

    hyprctl reload

    hyprctl dispatch 'hl.dsp.focus({ monitor = 0 })'
fi
