#! /bin/bash
for d in $(find . -name .git -type d -prune); do
    cd $(dirname $d)
    for f in $(git status --porcelain | awk '{ print $2 }'); do
        file=$(echo $(dirname $d)/$f | cut -c3-)
        echo "$(pwd)/$f to $1/$file"
        if [[ "$1" != "dry" ]]; then
            scp $(pwd)/$f $1/$file
        fi
    done
    cd - > /dev/null
done
