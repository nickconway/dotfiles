#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

case $1 in
bar)
    if pgrep -afx "qs .*caelestia.*" &>/dev/null; then
        qs -c caelestia ipc call drawers toggle bar
    elif pgrep -afx "qs .*noctalia.*" &>/dev/null; then
        qs -c noctalia ipc call controlCenter toggle
    elif pgrep -afx "qs .*dms.*" &>/dev/null; then
        qs -c dms ipc call control-center toggle
    else
        killall waybar -SIGUSR1
    fi
    ;;

bit-depth)
    hyprctl monitors -j | jq -r ".[] | .name, .currentFormat" | xargs -n2 echo | while read -r LINE; do
        MONITOR="$(echo "$LINE" | awk '{print $1}')"
        FORMAT="$(echo "$LINE" | awk '{print $2}')"

        if [[ "$FORMAT" == "XRGB8888" ]]; then
            BITDEPTH=10
        else
            BITDEPTH=8
        fi

        if ! grep -q "$MONITOR" ~/.config/hypr/include/monitors.lua; then
            continue
        fi

        K="$(grep "^hl.monitor.*$MONITOR" ~/.config/hypr/include/monitors.lua | sed -r "s/bitdepth = \w+/bitdepth = $BITDEPTH/")"
        hyprctl eval "$K"
        notify-send -e "Set $MONITOR to bitdepth of $BITDEPTH" -h string:synchronous:bitdepth-"$MONITOR"
    done
    ;;

deck-hyprland)
    unset LD_PRELOAD
    xhost +si:localuser:$USER
    sudo chown -f -R $USER:$USER /tmp/.X11-unix
    /home/deck/.local/bin/distrobox enter arch --additional-flags "--env DISPLAY=${DISPLAY}" -- Hyprland
    ;;

dnd)
    if pgrep -afx "qs .*caelestia.*" &>/dev/null; then
        qs -c caelestia ipc call notifs toggleDnd
    elif pgrep -afx "qs .*noctalia.*" &>/dev/null; then
        qs -c noctalia ipc call notifications toggleDND
    elif pgrep -afx "qs .*dms.*" &>/dev/null; then
        qs -c dms ipc call notifications toggleDoNotDisturb
    else
        swaync-client -d
        if [[ $(swaync-client -D) == "false" ]]; then
            notify-send "Do Not Disturb" "Do not disturb is now off" -h string:synchronous:dnd -e
        fi
    fi
    ;;

zenbook-screen)
    shift

    export XDG_RUNTIME_DIR="/run/user/$(id -u $USER)"
    export HYPRLAND_INSTANCE_SIGNATURE=$(ls $XDG_RUNTIME_DIR/hypr/ 2>/dev/null | head -n1)

    if [[ $1 == off ]]; then
        hyprctl eval 'hl.monitor({ output = "eDP-2", disabled = true })'
        notify-send -e -h string:synchronous:zenbook-screen "Zenbook" "Second screen disabled"
    else
        hyprctl eval 'hl.monitor({ output = "eDP-2", disabled = false, mode = "preferred", position = "auto-down", scale = "1.6", bitdepth = 10 })'
        notify-send -e -h string:synchronous:zenbook-screen "Zenbook" "Second screen enabled"
    fi
    ;;
esac
