#!/usr/bin/env bash
set -euo pipefail

echo "Monitoring UPS Status..."

journalctl -t ups -n 0 -f | while read -r COMMAND; do
    COMMAND="$(rev <<<"$COMMAND" | cut -d ':' -f 1 | rev | xargs)"

    echo "Received: $COMMAND"

    case "$COMMAND" in
    ONLINE)
        touch /tmp/ups-online
        notify-send "UPS Status" "UPS Switched to Main Power" -h string:synchronous:ups -e
        ;;
    ONBATT)
        eval "$(notify-send "UPS Status" "UPS Switched to Battery Power" -h string:synchronous:ups -e -t 0 -u critical --action "[[ -e /tmp/ups-online ]] || shutdown=Shutdown")" &
        ;;
    esac
done
