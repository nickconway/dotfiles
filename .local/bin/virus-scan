#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

eval "$(
    get-options \
        "-r, --reset: reset=true" \
        "-p, --progress: progress=true" \
        -- \
        "$@"
)"

DIR="${ARGS[0]:-.}"

if [[ -n "${progress:-}" ]]; then
    scanned=$(cat "$DIR/.scan-log" | wc -l)
    total=$(cat "$DIR/.files" | wc -l)
    echo "$(bc -l <<<"result = $scanned / $total * 100; scale = 2; result / 1")%"
    exit
fi

freshclam

if [[ -e "$DIR/.scan" && -z "${reset:-}" ]]; then
    echo "Finding new files..."
    find "$DIR" -type f -cnewer "$DIR/.scan" &>"$DIR/.files"
else
    echo "Getting files..."
    find "$DIR" -type f &>"$DIR/.files"
fi

echo "Scanning files..."

touch "$DIR/.scan"
clamscan --file-list "$DIR/.files" 2>"$DIR/.scan-error-log" >"$DIR/.scan-log" || true
tail "$DIR/.scan-log"

if grep -q "Infected files: [^0]" "$DIR/.scan-log"; then
    notifiy-send "Virus Scan" "Infected files found" -u critical
    curl -fsSL -d "Infected files found" "https://notifications.$SERVICES_BASE_DOMAIN/notifications" -H "Authorization: Bearer ${NTFY_TOKEN}" &>/dev/null
fi

rm "$DIR/.scan-log"
