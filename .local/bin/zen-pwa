#!/usr/bin/env bash
set -euo pipefail

URL="${1:-}"

if [[ -z $URL ]]; then
    URL="$(cat $HOME/.zen/*/taskbartabs/taskbartabs.json | jq -r ".taskbarTabs[] | .startUrl" | fzf)"
fi

FILE="$(cat $HOME/.zen/*/taskbartabs/taskbartabs.json | jq -r ".taskbarTabs[] | select(.startUrl == \"$URL\") | .shortcutRelativePath")"

if [[ -z "$FILE" ]]; then
    zen-browser -taskbar-tab $(uuidgen) -new-window "$URL"
else
    dex "$HOME/.local/share/applications/$FILE"
fi
