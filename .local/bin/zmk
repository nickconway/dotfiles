#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    export GUM_SPIN_SHOW_OUTPUT=true
    export GUM_SPIN_SHOW_STDOUT=true
fi

function get-board() {
    if [[ -z "${board}" ]]; then
        board="$(yq '.type + " " + .id' $(fd .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR/extra-modules 2>/dev/null) | grep -v '\---' | grep '^board' | sed 's/\/\/zmk//' | sed 's/^board //' | sort | uniq | fzf)"
    fi

    BUILD_FLAGS+=(-b "${board%//zmk}//zmk")
}

function get-shield() {
    if [[ -z "${shields:-}" ]]; then
        shields+=(
            $(
                (
                    yq '.type + " " + .id' $(fd .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR/extra-modules 2>/dev/null) | grep -v '\---' | grep '^shield' | sed 's/\/\/zmk//' | sed 's/^shield //'
                    rg --no-filename -o 'shields_list_contains,\w*' $ZMK_DIR $ZMK_CONFIG_DIR/extra-modules | sed 's/shields_list_contains,//' | grep -v '^$'
                ) | sort | uniq | fzf
            )
        )
    fi
}

function get-modules() {
    if [[ -e "$ZMK_CONFIG_DIR/extra-modules" ]] && [[ -z "${modules:-}" ]]; then
        PREFIX="$ZMK_CONFIG_DIR"

        if [[ -n ${DOCKER:-} ]]; then
            PREFIX="/workspaces/zmk-config"
        fi

        modules="$(yq '.manifest.projects[].path' $(fd west.yml $ZMK_CONFIG_DIR{,/extra-modules}) | grep -v '\---' | grep -v null | while read -r p; do
            echo "$PREFIX/$p"
        done | xargs | sed 's/ /;/g')"

        if [[ -n "$modules" ]]; then
            CMAKE_BASE+=" -DZMK_EXTRA_MODULES='$modules'"
        fi
    fi
}

function clean() {
    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{.bkp,}
    fi

    if [[ -e "$ZMK_CONFIG_DIR"/config/include/macros.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{.bkp,}
    fi

    if [[ -e tmp ]]; then
        if mountpoint -q tmp; then
            sudo umount tmp
        fi
        rmdir tmp
    fi
}

trap clean ERR EXIT

CMAKE_BASE="-DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DZMK_CONFIG=/workspaces/zmk-config"

function get-dirs() {
    CMAKE_ARGS=()
    BUILD_DIRS=()
    SHIELDS=()
    IS_SPLIT=false

    OLD_BASE="${shields[0]}"

    BASE="$OLD_BASE"

    for e in dongle left right; do
        BASE="${BASE%_"$e"}"
    done

    for e in dongle left right; do
        if find "$ZMK_DIR" "$ZMK_CONFIG_DIR/extra-modules" -name ${BASE}_${e}.overlay 2>/dev/null | grep -q .; then
            IS_SPLIT=true
        fi
    done

    if [[ "$IS_SPLIT" == true ]]; then
        for e in dongle left right; do
            if find "$ZMK_DIR" "$ZMK_CONFIG_DIR/extra-modules" -name ${BASE}_${e}.overlay 2>/dev/null | grep -q . && { [[ "$OLD_BASE" == "$BASE" ]] || [[ "$OLD_BASE" == *"_${e}" ]]; }; then
                CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE}_${e} ${shields[*]:1}'")
                BUILD_DIRS+=("${DOCKER:+docker/}$board/$BASE/$(echo ${shields[*]:1} | sed 's/ /_/g')${snippet:+_$snippet}/$e")
                SHIELDS+=("${BASE}_$e")
            fi
        done
    else
        CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE} ${shields[*]:1}'")
        BUILD_DIRS+=("${DOCKER:+docker/}$board/$BASE/$(echo ${shields[*]:1} | sed 's/ /_/g')${snippet:+_$snippet}")
        SHIELDS+=("$BASE")
    fi
}

function build() {
    cd "$ZMK_DIR"

    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi ]]; then
        cp "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{,.bkp}
        cp "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{,.bkp}

        cat ~/.config/zmk/leader.dtsi >>"$ZMK_CONFIG_DIR"/config/include/leader.dtsi
        cat ~/.config/zmk/macros.dtsi >>"$ZMK_CONFIG_DIR"/config/include/macros.dtsi
    fi

    get-modules
    get-board
    get-shield
    get-dirs "$@"

    for ((index = 0; index < ${#BUILD_DIRS[@]}; index++)); do
        if ! grep -q "^CACHED_SNIPPET:STRING=$snippet$" "$ZMK_DIR/app/build/${BUILD_DIRS[$index]}/CMakeCache.txt" 2>/dev/null; then
            BUILD_FLAGS+=(-p)
        fi

        cd "$ZMK_DIR"
        uvx west config build.cmake-args -- "${CMAKE_ARGS[$index]}"

        cd "$ZMK_DIR/app"

        if [[ -z ${DOCKER:-} ]]; then
            gum spin --title "Building ${SHIELDS[$index]}" -- west build ${BUILD_FLAGS[*]} -d build/${BUILD_DIRS[$index]}
        else
            gum spin --title "Building ${SHIELDS[$index]}" -- bash -c "docker-run west build ${BUILD_FLAGS[*]} -d build/${BUILD_DIRS[$index]}"
        fi
    done
}

function docker-run() {
    docker run \
        -u $UID \
        -v "${ZMK_DIR}":/workspaces/zmk \
        -v "${ZMK_CONFIG_DIR}":/workspaces/zmk-config \
        -w /workspaces/zmk/app \
        --rm \
        zmk "$@"
}

function wait-for-dev() {
    while [[ ! -e /dev/$disk ]]; do
        true
    done
}

function wait-for-complete() {
    while [[ -e /dev/$disk ]]; do
        true
    done
}

export -f docker-run wait-for-dev wait-for-complete

function flash() {
    get-board
    get-shield
    get-dirs "$@"

    export disk

    for ((index = $((${#BUILD_DIRS[@]} - 1)); index >= 0; index--)); do
        mkdir tmp

        gum spin --title "Set ${SHIELDS[$index]} to flashing mode..." -- bash -c wait-for-dev

        sudo mount /dev/$disk tmp
        sudo cp $ZMK_DIR/app/build/${BUILD_DIRS[$index]}/zephyr/zmk.uf2 tmp

        gum spin --title "Flashing ${SHIELDS[$index]}..." -- bash -c wait-for-complete

        clean
    done
}

function log() {
    if [[ -n "${RG_FLAGS:-}" ]]; then
        (sudo tio $tty_dev) </dev/tty | rg "${RG_FLAGS[@]}"
    else
        (sudo tio $tty_dev) </dev/tty
    fi
}

function test() {
    cd "$ZMK_DIR/app"
    uvx west config build.cmake-args -- ""
    "${TEST_ARGS[@]}" uvx west test tests/${1:-}
}

function _update() {
    cd $1

    if [[ ! -e .west ]]; then
        uvx west init -l $2
    fi

    uvx west update --fetch-opt=--filter=tree:0
    uvx west zephyr-export
}

function update() {
    _update $ZMK_CONFIG_DIR config
    _update $ZMK_DIR app
}

board=
disk=sda
shields=()
snippet=
tty_dev=/dev/ttyACM0

BUILD_FLAGS=()
TEST_ARGS=()

OPTS_STRING+=("-b, --board: board='\$ARG'")
OPTS_STRING+=("-g, --search: RG_FLAGS+=(-i '\$ARG')")
OPTS_STRING+=("-l, --log: BUILD_FLAGS+=(-S zmk-usb-logging); snippet=zmk-usb-logging")
OPTS_STRING+=("-o, --passthrough, --passthru: RG_FLAGS+=(--passthrough)")
OPTS_STRING+=("-p, --pristine: BUILD_FLAGS+=(-p)")
OPTS_STRING+=("-s, --shield: shields+=(\$ARG)")
OPTS_STRING+=("-v, --verbose: TEST_ARGS+=('ZMK_TESTS_VERBOSE=y')")
OPTS_STRING+=("-y, --tty: tty_dev='\$ARG'")
eval "$(get-options "${OPTS_STRING[@]}" -- "$@")"

if [[ -z "${ZMK_DIR:-}" ]]; then
    ZMK_DIR="$ZMK_CONFIG_DIR/zmk"
fi

if ! docker image inspect zmk &>/dev/null; then
    docker build $ZMK_DIR/.devcontainer -t zmk
fi

for c in "${ARGS[@]}"; do
    $c
done
