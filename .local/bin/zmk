#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

function get-board() {
    if [[ -z "${board}" ]]; then
        board="$(
            (
                cd "$ZMK_CONFIG_DIR/.."
                yq '.board.name' $(fd board.yml)
                yq '.include[].board' $(fd build.yaml)
            ) | grep '\w' | sort | uniq | fzf
        )"
    fi

    BUILD_FLAGS+=(-b "${board}")
}

function get-shield() {
    if [[ -z "${shield}" ]]; then
        shield="$(
            (
                cd $ZMK_DIR/app/boards/shields && fd --type d
                cd $ZMK_CONFIG_DIR/config/boards/shields && fd --type d
            ) | tr -d '/' | sort | uniq | fzf
        )"
    fi
}

function get-modules() {
    if [[ -e "$ZMK_CONFIG_DIR/extra-modules" ]] && [[ -z "${modules:-}" ]]; then
        modules="$(
            cd "$ZMK_CONFIG_DIR"/extra-modules
            fd --type d --max-depth 1 | tr -d '/' | fzf | while read -r M; do
                echo /config/extra-modules/$M
            done | xargs | sed 's/ /,/g'
        )"
    fi
}

function clean() {
    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{.bkp,}
    fi

    if [[ -e "$ZMK_CONFIG_DIR"/config/include/macros.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{.bkp,}
    fi

    [[ -e app/.clangd ]] && rm app/.clangd

    if [[ -e tmp ]]; then
        if mountpoint -q tmp; then
            sudo umount tmp
        fi
        rmdir tmp
    fi
}

trap clean ERR EXIT

CMAKE_BASE="-DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DZMK_CONFIG=/config/config"

cd "$ZMK_DIR"

function zmk-run() {
    docker run \
        -v "${ZMK_DIR}":/workspace \
        -v "${ZMK_CONFIG_DIR}":/config \
        -w /workspace/app \
        --rm \
        zmk "$@"
}

function get-dirs() {
    OLD_BASE="${shield:-}"

    BASE="$OLD_BASE"
    BASE="${BASE%_left}"
    BASE="${BASE%_right}"

    CMAKE_ARGS=()
    BUILD_DIRS=()
    SHIELDS=()

    IS_SPLIT=false
    if [[ $(find "$ZMK_DIR" "$ZMK_CONFIG_DIR" -name ${BASE}_left.conf | wc -l) -gt 0 ]]; then
        IS_SPLIT=true
    fi

    if [[ "$IS_SPLIT" == true ]]; then
        if [[ "$OLD_BASE" == "$BASE" ]] || [[ "$OLD_BASE" == *"_left" ]]; then
            if [[ $niceview == true ]]; then
                CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE}_left nice_view_adapter nice_view${niceview_ext:+_$niceview_ext}'")
                BUILD_DIRS+=("$board/$BASE/nice-view${niceview_ext:+-$niceview_ext}/left")
            else
                CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD=${BASE}_left")
                BUILD_DIRS+=("$board/$BASE/left")
            fi

            SHIELDS+=("${BASE}_left")
        fi

        if [[ "$OLD_BASE" == "$BASE" ]] || [[ "$OLD_BASE" == *"_right" ]]; then
            if [[ $niceview == true ]]; then
                CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE}_right nice_view_adapter nice_view${niceview_ext:+_$niceview_ext}'")
                BUILD_DIRS+=("$board/$BASE/nice-view${niceview_ext:+-$niceview_ext}/right")
            else
                CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD=${BASE}_right")
                BUILD_DIRS+=("$board/$BASE/right")
            fi

            SHIELDS+=("${BASE}_right")
        fi
    else
        if [[ $niceview == true ]]; then
            CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE} nice_view_adapter nice_view${niceview_ext:+_$niceview_ext}'")
            BUILD_DIRS+=("$board/$BASE/nice-view${niceview_ext:+-$niceview_ext}")
        else
            CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD=${BASE}")
            BUILD_DIRS+=("$board/$BASE")
        fi

        SHIELDS+=("$BASE")
    fi

    if [[ $reset == true ]]; then
        BUILD_FLAGS=(-b "$board")
        CMAKE_ARGS=("-DSHIELD=settings_reset")

        length=${#BUILD_DIRS[@]}
        BUILD_DIRS=()
        for ((index = 0; index < length; index++)); do
            BUILD_DIRS+=("settings-reset")
        done
    fi
}

function build() {
    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi ]]; then
        cp "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{,.bkp}
        cp "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{,.bkp}

        cat ~/.config/zmk/leader.dtsi >>"$ZMK_CONFIG_DIR"/config/include/leader.dtsi
        cat ~/.config/zmk/macros.dtsi >>"$ZMK_CONFIG_DIR"/config/include/macros.dtsi
    fi

    cat <<EOF >app/.clangd
        CompileFlags:
        Add: -Wno-unknown-warning-option
        Remove: [-m*, -f*]
EOF

    get-board
    get-shield
    get-dirs "$@"

    for ((index = 0; index < ${#BUILD_DIRS[@]}; index++)); do
        if ! grep "^CACHED_SNIPPET:STRING=$snippet$" "app/build/${BUILD_DIRS[$index]}/CMakeCache.txt" &>/dev/null; then
            BUILD_FLAGS+=(-p)
        fi

        zmk-run west config build.cmake-args -- "${CMAKE_ARGS[$index]}"
        gum spin --title "Building ${SHIELDS[$index]}" -- bash -c "zmk-run west build ${BUILD_FLAGS[*]} -d build/${BUILD_DIRS[$index]}"
    done
}

function wait-for-dev() {
    while [[ ! -e /dev/disk/by-label/NICENANO ]]; do
        true
    done
}

function wait-for-complete() {
    while [[ -e /dev/disk/by-label/NICENANO ]]; do
        true
    done
}

export -f zmk-run wait-for-dev wait-for-complete

function flash() {
    get-board
    get-shield
    get-dirs "$@"

    for ((index = $((${#BUILD_DIRS[@]} - 1)); index >= 0; index--)); do
        mkdir tmp

        gum spin --title "Set ${SHIELDS[$index]} to flashing mode..." -- bash -c wait-for-dev

        sudo mount /dev/disk/by-label/NICENANO tmp
        sudo cp app/build/${BUILD_DIRS[$index]}/zephyr/zmk.uf2 tmp

        gum spin --title "Flashing ${SHIELDS[$index]}..." -- bash -c wait-for-complete

        clean
    done
}

function log() {
    if [[ -n "${RG_FLAGS:-}" ]]; then
        (sudo tio /dev/ttyACM0) </dev/tty | rg "${RG_FLAGS[@]}"
    else
        (sudo tio /dev/ttyACM0) </dev/tty
    fi
}

function test() {
    zmk-run bash -xc "${TEST_ARGS[*]} west test tests/${shield}"
}

function update() {
    zmk-run bash -c "cd ${1:-.} && west update --fetch-opt=--filter=tree:0 && west zephyr-export"
}

board=
module_flag=
modules=
shield=
snippet=
niceview=false
reset=false

BUILD_FLAGS=()
TEST_ARGS=()

OPTS_STRING+=("-b,--board:board='\$ARG'")
OPTS_STRING+=("-g,--search:RG_FLAGS+=(-i '\$ARG')")
OPTS_STRING+=("-l,--log:BUILD_FLAGS+=(-S zmk-usb-logging)")
OPTS_STRING+=("-m,--modules:module_flag=true\; modules='\$ARG'")
OPTS_STRING+=("-n,--nice-view:niceview=true\; niceview_ext='\$ARG'")
OPTS_STRING+=("-o,--passthrough,--passthru:RG_FLAGS+=(--passthrough)")
OPTS_STRING+=("-p,--pristine:BUILD_FLAGS+=(-p)")
OPTS_STRING+=("-r,--reset:reset=true")
OPTS_STRING+=("-s,--shield:shield='\$ARG'")
OPTS_STRING+=("-v,--verbose:TEST_ARGS+=('ZMK_TESTS_VERBOSE=y')")
eval "$(get-options "${OPTS_STRING[@]}" -- "$@")"

if [[ -n "$module_flag" ]] && [[ -z "$modules" ]]; then
    get-modules
fi

if [[ -n "$modules" ]]; then
    CMAKE_BASE+=" -DZMK_EXTRA_MODULES=$modules"
fi

if ! docker image inspect zmk &>/dev/null; then
    docker build .devcontainer -t zmk
fi

if [[ ! -e .west ]]; then
    zmk-run bash -c "west init -l ."
    update
fi

if [[ ! -e "$ZMK_CONFIG_DIR"/.west ]]; then
    zmk-run bash -c "cd /config/config && west init -l ."
    update /config/config
fi

for c in "${ARGS[@]}"; do
    "$c"
done
