#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    export GUM_SPIN_SHOW_OUTPUT=true
    export GUM_SPIN_SHOW_STDOUT=true
fi

function get-board() {
    if [[ -z "${board}" ]]; then
        REQ="$(
            yq "select(.type == \"shield\" and (.id == \"${shields[0]}\" or .siblings[] | contains(\"${shields[0]}\"))) | .requires | join(\" \")" $(fd --no-ignore .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR) |
                grep -v '\---' | sort | uniq
        )"

        board="$(
            yq 'select(.type == "board" and .exposes[] | contains("'$REQ'")) | .id' $(fd --no-ignore .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR) | grep -v '\---' |
                sed 's/\/\/zmk//' | sort | uniq | fzf
        )"
    fi

    BUILD_FLAGS+=(-b "${board%//zmk}//zmk")
}

function get-shield() {
    if [[ -z "${shields:-}" ]]; then
        shields+=(
            $(
                (
                    yq 'select(.type == "shield") | .id' $(fd --no-ignore .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR)
                    yq 'select(.type == "shield") | .siblings[]' $(fd --no-ignore .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR)
                    rg --no-filename --no-ignore -o 'shields_list_contains,\w*' | sed 's/shields_list_contains,//'
                ) | grep . | grep -v '\---' | sort | uniq | fzf
            )
        )
    fi
}

function _get_west_files() {
    (
        yq '.manifest.projects[] | select(.path and .import) | .path + "/" + .import' $1
        yq '.manifest.projects[] | select(.path == null and .import) | .name + "/" + .import' $1
    ) | grep -v '^zmk'
}

function _get_modules() {
    (
        yq '.manifest.projects[] | select(.path) | .path' $1
        yq '.manifest.projects[] | select(.path == null) | .name' $1
    ) | grep -v '^zmk' | while read -r M; do
        if [[ -e $ZMK_CONFIG_DIR/$M ]]; then
            echo "$PREFIX/$M"
        fi
    done
}

function _get_all_modules() {
    _get_modules $1

    _get_west_files $1 | while read -r f; do
        _get_all_modules $f
    done

    return 0
}

function get-modules() {
    if [[ -e "$ZMK_CONFIG_DIR/extra-modules" ]] && [[ -z "${modules:-}" ]]; then
        PREFIX="$ZMK_CONFIG_DIR"

        if [[ -n ${DOCKER:-} ]]; then
            PREFIX="/workspaces/zmk-config"
        fi

        modules="$(_get_all_modules $ZMK_CONFIG_DIR/config/west.yml | xargs | sed 's/ /;/g')"

        if [[ -n "$modules" ]]; then
            CMAKE_BASE+=" -DZMK_EXTRA_MODULES='$modules'"
        fi
    fi
}

function clean() {
    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{.bkp,}
    fi

    if [[ -e "$ZMK_CONFIG_DIR"/config/include/macros.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{.bkp,}
    fi

    if [[ -e tmp ]]; then
        if mountpoint -q tmp; then
            sudo umount tmp
        fi
        rmdir tmp
    fi

    if [[ -n ${TPID:-} ]]; then
        kill $TPID
    fi

    rm -f /tmp/zmk.log
}

trap clean ERR EXIT

function get-dirs() {
    CMAKE_ARGS=()
    BUILD_DIRS=()
    SHIELDS=()
    IS_SPLIT=false

    OLD_BASE="${shields[0]}"

    BASE="$OLD_BASE"

    for e in dongle left right; do
        BASE="${BASE%_"$e"}"
    done

    for e in dongle left right; do
        if find "$ZMK_DIR" "$ZMK_CONFIG_DIR" -name ${BASE}_${e}.overlay 2>/dev/null | grep -q .; then
            IS_SPLIT=true
        fi
    done

    if [[ "$IS_SPLIT" == true ]]; then
        for e in dongle left right; do
            if find "$ZMK_DIR" "$ZMK_CONFIG_DIR" -name ${BASE}_${e}.overlay 2>/dev/null | grep -q . && { [[ "$OLD_BASE" == "$BASE" ]] || [[ "$OLD_BASE" == *"_${e}" ]]; }; then
                CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE}_${e} ${shields[*]:1}'")
                BUILD_DIRS+=("${DOCKER:+docker/}$board/$BASE/$e/$(echo ${shields[*]:1} | sed 's/ /_/g')${snippet:+_$snippet}")
                SHIELDS+=("${BASE}_$e")
            fi
        done
    else
        CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE} ${shields[*]:1}'")
        BUILD_DIRS+=("${DOCKER:+docker/}$board/$BASE/$(echo ${shields[*]:1} | sed 's/ /_/g')${snippet:+_$snippet}")
        SHIELDS+=("$BASE")
    fi
}

function build() {
    CMAKE_BASE="-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"

    if [[ -z ${DOCKER:-} ]]; then
        CMAKE_BASE+=" -DZMK_CONFIG=$ZMK_CONFIG_DIR/config"
    else
        CMAKE_BASE+=" -DZMK_CONFIG=/workspaces/zmk-config/config"
    fi

    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi ]]; then
        cp "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{,.bkp}
        cp "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{,.bkp}

        cat ~/.config/zmk/leader.dtsi >>"$ZMK_CONFIG_DIR"/config/include/leader.dtsi
        cat ~/.config/zmk/macros.dtsi >>"$ZMK_CONFIG_DIR"/config/include/macros.dtsi
    fi

    cd "$ZMK_CONFIG_DIR"

    get-modules
    get-shield
    get-board
    get-dirs "$@"

    cd "$ZMK_DIR/app"

    for ((index = 0; index < ${#BUILD_DIRS[@]}; index++)); do
        if ! grep -q "^CACHED_SNIPPET:STRING=$snippet$" "$ZMK_DIR/app/build/${BUILD_DIRS[$index]}/CMakeCache.txt" 2>/dev/null; then
            BUILD_FLAGS+=(-p)
        fi

        if ! grep -q "^ZMK_EXTRA_MODULES:UNINITIALIZED=$modules$" "$ZMK_DIR/app/build/${BUILD_DIRS[$index]}/CMakeCache.txt" 2>/dev/null; then
            BUILD_FLAGS+=(-p)
        fi

        uvx west config build.cmake-args -- "${CMAKE_ARGS[$index]}"

        if [[ -z ${DOCKER:-} ]]; then
            gum spin --title "Building ${SHIELDS[$index]}" -- west build ${BUILD_FLAGS[*]} -d build/${BUILD_DIRS[$index]}
        else
            gum spin --title "Building ${SHIELDS[$index]}" -- bash -c "docker-run west build ${BUILD_FLAGS[*]} -d build/${BUILD_DIRS[$index]}"
        fi
    done
}

function docker-run() {
    docker run \
        -u $UID \
        -v "${ZMK_DIR}":/workspaces/zmk \
        -v "${ZMK_CONFIG_DIR}":/workspaces/zmk-config \
        -w /workspaces/zmk/app \
        --rm \
        zmk "$@"
}

function wait-for-dev() {
    while [[ ! -e /dev/$disk ]]; do
        true
    done
}

function wait-for-complete() {
    while [[ -e /dev/$disk ]]; do
        true
    done
}

export -f docker-run wait-for-dev wait-for-complete

function flash() {
    get-shield
    get-board
    get-dirs "$@"

    export disk

    for ((index = $((${#BUILD_DIRS[@]} - 1)); index >= 0; index--)); do
        mkdir tmp

        gum spin --title "Set ${SHIELDS[$index]} to flashing mode..." -- bash -c wait-for-dev

        sudo mount /dev/$disk tmp
        sudo cp $ZMK_DIR/app/build/${BUILD_DIRS[$index]}/zephyr/zmk.uf2 tmp

        gum spin --title "Flashing ${SHIELDS[$index]}..." -- bash -c wait-for-complete

        clean
    done
}

function log() {
    (
        if [[ -n "${RG_FLAGS:-}" ]]; then
            sudo tio $tty_dev | rg "${RG_FLAGS[@]}"
        else
            sudo tio $tty_dev
        fi
    ) &>/tmp/zmk.log &
    disown
    TPID=$!
    tail -f /tmp/zmk.log
}

function test() {
    cd "$ZMK_DIR/app"
    uvx west config build.cmake-args -- ""

    if [[ -z ${DOCKER:-} ]]; then
        "${TEST_ARGS[@]}" uvx west test tests/${1:-}
    else
        docker-run bash -c "${TEST_ARGS[*]} west test tests/${1:-}"
    fi
}

function _update() {
    cd $1

    if [[ ! -e .west ]]; then
        uvx west init -l $2
    fi

    uvx west update --fetch-opt=--filter=tree:0
    uvx west zephyr-export
}

function update() {
    _update $ZMK_CONFIG_DIR config
    _update $ZMK_DIR app
}

board=
disk=sda
shields=()
snippet=
tty_dev=/dev/ttyACM0

BUILD_FLAGS=()
TEST_ARGS=()

OPTS_STRING+=("-b, --board: board='\$ARG'")
OPTS_STRING+=("-d, --docker: DOCKER=true")
OPTS_STRING+=("-g, --search: RG_FLAGS+=(-i '\$ARG')")
OPTS_STRING+=("-l, --log: BUILD_FLAGS+=(-S zmk-usb-logging); snippet=zmk-usb-logging")
OPTS_STRING+=("-o, --passthrough, --passthru: RG_FLAGS+=(--passthrough)")
OPTS_STRING+=("-p, --pristine: BUILD_FLAGS+=(-p)")
OPTS_STRING+=("-s, --shield: shields+=(\$ARG)")
OPTS_STRING+=("-v, --verbose: TEST_ARGS+=('ZMK_TESTS_VERBOSE=y')")
OPTS_STRING+=("-y, --tty: tty_dev='\$ARG'")
eval "$(get-options "${OPTS_STRING[@]}" -- "$@")"

if [[ -z "${ZMK_DIR:-}" ]]; then
    ZMK_DIR="$ZMK_CONFIG_DIR/zmk"
fi

if ! docker image inspect zmk &>/dev/null; then
    docker build $ZMK_DIR/.devcontainer -t zmk
fi

for c in "${ARGS[@]}"; do
    $c
done
