#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LOG:-}" ]]; then
    exec &>"/tmp/$(basename "$0").log"
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    set -x
fi

if [[ -n "${DEBUG_MODE:-}" ]]; then
    export GUM_SPIN_SHOW_OUTPUT=true
    export GUM_SPIN_SHOW_STDOUT=true
fi

function get-board() {
    if [[ -z "${board}" ]]; then
        board="$(yq '.type + " " + .id' $(fd .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR/extra-modules 2>/dev/null) | grep -v '\---' | grep '^board' | sed 's/\/\/zmk//' | sed 's/^board //' | sort | uniq | fzf)"
    fi

    BUILD_FLAGS+=(-b "${board%//zmk}//zmk")
}

function get-shield() {
    if [[ -z "${shields:-}" ]]; then
        shields+=(
            $(
                (
                    yq '.type + " " + .id' $(fd .zmk.yml $ZMK_DIR $ZMK_CONFIG_DIR/extra-modules 2>/dev/null) | grep -v '\---' | grep '^shield' | sed 's/\/\/zmk//' | sed 's/^shield //'
                    rg --no-filename -o 'shields_list_contains,\w*' $ZMK_DIR $ZMK_CONFIG_DIR/extra-modules | sed 's/shields_list_contains,//' | grep -v '^$'
                ) | sort | uniq | fzf
            )
        )
    fi
}

function get-modules() {
    if [[ -e "$ZMK_CONFIG_DIR/extra-modules" ]] && [[ -z "${modules:-}" ]]; then
        modules="$(
            cd "$ZMK_CONFIG_DIR"/extra-modules
            fd --type d --max-depth 1 | tr -d '/' | while read -r M; do
                echo /config/extra-modules/$M
            done | xargs | sed 's/ /;/g'
        )"

        if [[ -n "$modules" ]]; then
            CMAKE_BASE+=" -DZMK_EXTRA_MODULES='$modules'"
        fi
    fi
}

function clean() {
    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{.bkp,}
    fi

    if [[ -e "$ZMK_CONFIG_DIR"/config/include/macros.dtsi.bkp ]]; then
        mv "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{.bkp,}
    fi

    [[ -e app/.clangd ]] && rm app/.clangd

    if [[ -e tmp ]]; then
        if mountpoint -q tmp; then
            sudo umount tmp
        fi
        rmdir tmp
    fi
}

trap clean ERR EXIT

CMAKE_BASE="-DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DZMK_CONFIG=/config/config"

cd "$ZMK_DIR"

function zmk-run() {
    docker run \
        -v "${ZMK_DIR}":/workspace \
        -v "${ZMK_CONFIG_DIR}":/config \
        -w /workspace/app \
        --rm \
        zmk "$@"
}

function get-dirs() {
    OLD_BASE="${shields[0]}"

    BASE="$OLD_BASE"
    BASE="${BASE%_left}"
    BASE="${BASE%_right}"

    CMAKE_ARGS=()
    BUILD_DIRS=()
    SHIELDS=()

    IS_SPLIT=false
    if [[ $(find "$ZMK_DIR" "$ZMK_CONFIG_DIR" -name ${BASE}_left.conf | wc -l) -gt 0 ]]; then
        IS_SPLIT=true
    fi

    if [[ "$IS_SPLIT" == true ]]; then
        if [[ "$OLD_BASE" == "$BASE" ]] || [[ "$OLD_BASE" == *"_left" ]]; then
            CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE}_left ${shields[*]:1}'")
            BUILD_DIRS+=("$board/$BASE/left/$(echo ${shields[*]:1} | sed 's/ /_/g')${snippet:+_$snippet}")
            SHIELDS+=("${BASE}_left")
        fi

        if [[ "$OLD_BASE" == "$BASE" ]] || [[ "$OLD_BASE" == *"_right" ]]; then
            CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE}_right ${shields[*]:1}'")
            BUILD_DIRS+=("$board/$BASE/right/$(echo ${shields[*]:1} | sed 's/ /_/g')${snippet:+_$snippet}")
            SHIELDS+=("${BASE}_right")
        fi
    else
        CMAKE_ARGS+=("$CMAKE_BASE -DSHIELD='${BASE} ${shields[*]:1}'")
        BUILD_DIRS+=("$board/$BASE/$(echo ${shields[*]:1} | sed 's/ /_/g')${snippet:+_$snippet}")
        SHIELDS+=("$BASE")
    fi
}

function build() {
    if [[ -e "$ZMK_CONFIG_DIR"/config/include/leader.dtsi ]]; then
        cp "$ZMK_CONFIG_DIR"/config/include/leader.dtsi{,.bkp}
        cp "$ZMK_CONFIG_DIR"/config/include/macros.dtsi{,.bkp}

        cat ~/.config/zmk/leader.dtsi >>"$ZMK_CONFIG_DIR"/config/include/leader.dtsi
        cat ~/.config/zmk/macros.dtsi >>"$ZMK_CONFIG_DIR"/config/include/macros.dtsi
    fi

    cat <<EOF >app/.clangd
        CompileFlags:
        Add: -Wno-unknown-warning-option
        Remove: [-m*, -f*]
EOF

    get-modules
    get-board
    get-shield
    get-dirs "$@"

    for ((index = 0; index < ${#BUILD_DIRS[@]}; index++)); do
        if ! grep -q "^CACHED_SNIPPET:STRING=$snippet$" "app/build/${BUILD_DIRS[$index]}/CMakeCache.txt" 2>/dev/null; then
            BUILD_FLAGS+=(-p)
        fi

        zmk-run west config build.cmake-args -- "${CMAKE_ARGS[$index]}"
        gum spin --title "Building ${SHIELDS[$index]}" -- bash -c "zmk-run west build ${BUILD_FLAGS[*]} -d build/${BUILD_DIRS[$index]}"
    done
}

function wait-for-dev() {
    while [[ ! -e /dev/$disk ]]; do
        true
    done
}

function wait-for-complete() {
    while [[ -e /dev/$disk ]]; do
        true
    done
}

export -f zmk-run wait-for-dev wait-for-complete

function flash() {
    get-board
    get-shield
    get-dirs "$@"

    export disk

    for ((index = $((${#BUILD_DIRS[@]} - 1)); index >= 0; index--)); do
        mkdir tmp

        gum spin --title "Set ${SHIELDS[$index]} to flashing mode..." -- bash -c wait-for-dev

        sudo mount /dev/$disk tmp
        sudo cp app/build/${BUILD_DIRS[$index]}/zephyr/zmk.uf2 tmp

        gum spin --title "Flashing ${SHIELDS[$index]}..." -- bash -c wait-for-complete

        clean
    done
}

function log() {
    if [[ -n "${RG_FLAGS:-}" ]]; then
        (sudo tio $tty_dev) </dev/tty | rg "${RG_FLAGS[@]}"
    else
        (sudo tio $tty_dev) </dev/tty
    fi
}

function test() {
    zmk-run bash -xc "${TEST_ARGS[*]} west test tests/${1:-}"
}

function update() {
    zmk-run bash -c "cd ${1:-.} && west update --fetch-opt=--filter=tree:0 && west zephyr-export"
}

board=
disk=sda
shields=()
snippet=
tty_dev=/dev/ttyACM0

BUILD_FLAGS=()
TEST_ARGS=()

OPTS_STRING+=("-b, --board: board='\$ARG'")
OPTS_STRING+=("-g, --search: RG_FLAGS+=(-i '\$ARG')")
OPTS_STRING+=("-l, --log: BUILD_FLAGS+=(-S zmk-usb-logging); snippet=zmk-usb-logging")
OPTS_STRING+=("-o, --passthrough, --passthru: RG_FLAGS+=(--passthrough)")
OPTS_STRING+=("-p, --pristine: BUILD_FLAGS+=(-p)")
OPTS_STRING+=("-s, --shield: shields+=(\$ARG)")
OPTS_STRING+=("-v, --verbose: TEST_ARGS+=('ZMK_TESTS_VERBOSE=y')")
OPTS_STRING+=("-y, --tty: tty_dev='\$ARG'")
eval "$(get-options "${OPTS_STRING[@]}" -- "$@")"

if ! docker image inspect zmk &>/dev/null; then
    docker build .devcontainer -t zmk
fi

if [[ ! -e .west ]]; then
    zmk-run bash -c "west init -l ."
    update
fi

if [[ ! -e "$ZMK_CONFIG_DIR"/.west ]]; then
    zmk-run bash -c "cd /config/config && west init -l ."
    update /config/config
fi

for c in "${ARGS[@]}"; do
    $c
done
