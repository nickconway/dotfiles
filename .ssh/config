AddKeysToAgent yes

Host desktop
    User nickc
Match originalhost desktop exec "[[ $(dig +short home.conway.dev) == '10.0.107.2' ]]"
    Hostname 10.0.0.2
Match originalhost desktop
    Hostname desktop

Host laptop
    User nick
Match originalhost laptop exec "[[ $(dig +short home.conway.dev) == '10.0.107.2' ]]"
    Hostname 10.0.0.3
Match originalhost laptop
    Hostname laptop

Host steamdeck
    User deck
Match originalhost steamdeck exec "[[ $(dig +short home.conway.dev) == '10.0.107.2' ]]"
    Hostname 10.0.0.5
Match originalhost steamdeck
    Hostname steamdeck

Host server
    User nick
Match originalhost server exec "[[ $(dig +short home.conway.dev) == '10.0.107.2' ]]"
    Hostname 10.0.107.2
Match originalhost server
    Hostname server

Host macbook
    User nick
Match originalhost macbook exec "[[ $(dig +short home.conway.dev) == '10.0.107.2' ]]"
    Hostname 10.0.107.5
Match originalhost macbook
    Hostname macbook

Host work
    Hostname work
    User nick
    LocalForward 4200 0.0.0.0:4200

Host octopi
    Hostname octopi
    User nick

Host homeassistant
    User nick
Match originalhost homeassistant exec "[[ $(dig +short home.conway.dev) == '10.0.107.2' ]]"
    Hostname 10.0.107.3
Match originalhost homeassistant
    Hostname homeassistant

Host alma
    User nick
    LocalForward 9443 0.0.0.0:9443
Match originalhost alma exec "[[ ! -e ~/.work ]]"
    Hostname alma
    # ProxyJump work
Match originalhost alma exec "[[ -e ~/.work ]]"
    Hostname 192.168.220.137
